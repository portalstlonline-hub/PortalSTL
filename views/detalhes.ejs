<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= empresa.nome %> - Portal STL</title>
    
    <meta name="description" content="Conheça <%= empresa.nome %> em São Thomé das Letras. Categoria: <%= empresa.categoria_nome %>.">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SEU_CODIGO_AQUI"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SEU_CODIGO_AQUI');
    </script>
</head>
<body class="bg-gray-50 font-sans text-gray-800 antialiased">

    <nav class="bg-white/90 backdrop-blur-sm shadow-sm fixed w-full z-50 transition-all duration-300 border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <a href="/explorar" class="text-gray-500 hover:text-amber-500 font-bold transition flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
                <a href="/" class="flex-shrink-0">
                    <img src="/uploads/portallogomarca.png" alt="Portal STL" class="h-8 object-contain">
                </a>
            </div>
        </div>
    </nav>

    <header class="relative pt-16 h-[40vh] md:h-[50vh] bg-slate-900 flex items-end justify-center overflow-hidden">
        <% if(empresa.imagem) { %>
            <img src="<%= empresa.imagem %>" alt="<%= empresa.nome %>" class="absolute inset-0 w-full h-full object-cover opacity-60">
        <% } %>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/60 to-transparent"></div>
        
        <div class="relative z-10 text-center px-4 pb-12 max-w-4xl mx-auto">
            <span class="inline-block py-1 px-3 rounded-full bg-amber-500/20 border border-amber-400/50 text-amber-300 font-bold text-xs uppercase tracking-widest mb-3 backdrop-blur-sm">
                <%= empresa.categoria_nome || 'Local' %>
            </span>
            <h1 class="text-3xl md:text-5xl font-black text-white drop-shadow-lg"><%= empresa.nome %></h1>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 -mt-10 relative z-20">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 md:p-10 flex flex-col md:flex-row gap-10">
            
            <div class="flex-1">
                <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 flex items-center gap-2">
                    <i class="fas fa-info-circle text-amber-500"></i> Sobre o Local
                </h2>
                
                <div class="prose prose-amber max-w-none text-gray-600 leading-relaxed">
                    <% if (empresa.descricao) { %>
                        <p class="whitespace-pre-line"><%= empresa.descricao %></p>
                    <% } else { %>
                        <p class="italic text-gray-400">Nenhuma descrição fornecida pelo proprietário.</p>
                    <% } %>
                </div>

                <% 
                let fotos = [];
                if (empresa.galeria) {
                    try { fotos = JSON.parse(empresa.galeria); } catch(e) {}
                }
                %>
                <% if (fotos.length > 0) { %>
                    <h2 class="text-xl font-bold text-gray-900 mt-10 mb-4 border-b border-gray-100 pb-2 flex items-center gap-2">
                        <i class="fas fa-camera text-amber-500"></i> Galeria de Fotos
                    </h2>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                        <% fotos.forEach(foto => { %>
                            <a href="<%= foto %>" target="_blank" class="block h-32 md:h-40 overflow-hidden rounded-xl border border-gray-200 hover:shadow-lg transition">
                                <img src="<%= foto %>" class="w-full h-full object-cover hover:scale-110 transition duration-500" alt="Foto da Galeria">
                            </a>
                        <% }) %>
                    </div>
                <% } %>

                <% if (empresa.video_url) { %>
                    <h2 class="text-xl font-bold text-gray-900 mt-10 mb-4 border-b border-gray-100 pb-2 flex items-center gap-2">
                        <i class="fab fa-youtube text-red-500"></i> Vídeo
                    </h2>
                    <div class="aspect-w-16 aspect-h-9 rounded-xl overflow-hidden shadow-md">
                        <iframe src="<%= empresa.video_url %>" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="w-full h-64 md:h-96"></iframe>
                    </div>
                <% } %>
            </div>

            <div class="w-full md:w-80 flex-shrink-0">
                <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 sticky top-24">
                    <h3 class="font-black text-gray-900 text-lg mb-6 text-center uppercase tracking-wide">Fale com o Local</h3>
                    
                    <div class="space-y-4">
                        <% if (empresa.whatsapp) { %>
                            <a href="https://wa.me/<%= empresa.whatsapp.replace(/\D/g, '') %>" target="_blank" 
                               onclick="gtag('event', 'clique_whatsapp', { 'nome_empresa': '<%= empresa.nome %>', 'categoria': '<%= empresa.categoria_nome %>' });"
                               class="flex items-center justify-center w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-4 rounded-lg shadow-md transition transform hover:-translate-y-0.5 gap-2">
                                <i class="fab fa-whatsapp text-xl"></i> Chamar no WhatsApp
                            </a>
                        <% } %>

                        <% if (empresa.link_maps) { %>
                            <a href="<%= empresa.link_maps %>" target="_blank" 
                               onclick="gtag('event', 'clique_mapa', { 'nome_empresa': '<%= empresa.nome %>' });"
                               class="flex items-center justify-center w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-4 rounded-lg shadow-md transition transform hover:-translate-y-0.5 gap-2">
                                <i class="fas fa-map-marker-alt text-xl"></i> Como Chegar
                            </a>
                        <% } %>
                    </div>

                    <div class="mt-8 pt-6 border-t border-gray-200 space-y-4 text-sm text-gray-600">
                        <% if (empresa.endereco) { %>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-location-dot text-amber-500 mt-1"></i>
                                <span><%= empresa.endereco %></span>
                            </div>
                        <% } %>
                        
                        <% if (empresa.instagram) { %>
                            <div class="flex items-center gap-3">
                                <i class="fab fa-instagram text-pink-500"></i>
                                <a href="https://instagram.com/<%= empresa.instagram.replace('@', '') %>" target="_blank" 
                                   onclick="gtag('event', 'clique_instagram', { 'nome_empresa': '<%= empresa.nome %>' });"
                                   class="text-pink-600 font-bold hover:underline">
                                    <%= empresa.instagram %>
                                </a>
                            </div>
                        <% } %>
                        
                        <% if (empresa.site) { %>
                            <div class="flex items-center gap-3">
                                <i class="fas fa-globe text-blue-500"></i>
                                <a href="<%= empresa.site %>" target="_blank" class="text-blue-600 font-bold hover:underline truncate">Acessar Site</a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <footer class="bg-gray-900 text-white py-8 border-t border-gray-800 text-center mt-auto">
        <p class="text-gray-500 text-sm">© <%= new Date().getFullYear() %> Portal São Thomé das Letras. Operado por Resultados Online.</p>
    </footer>

    <!-- ========================================== -->
    <!-- 🍪 POP-UP LGPD (AVISO DE COOKIES)          -->
    <!-- ========================================== -->
    <div id="lgpd-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-8 md:w-[400px] bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 z-[9999] transform translate-y-full opacity-0 transition-all duration-500 flex flex-col pointer-events-none">
        <div class="flex items-start gap-4">
            <div class="text-4xl">🍪</div>
            <div>
                <h4 class="font-black text-slate-900 text-lg mb-1">Privacidade e Cookies</h4>
                <p class="text-sm text-slate-500 leading-relaxed mb-4">
                    Utilizamos cookies para melhorar a sua experiência, personalizar anúncios e gerar estatísticas de acesso. Ao continuar a navegar, você concorda com a nossa política de privacidade.
                </p>
            </div>
        </div>
        <div class="flex gap-3 mt-auto">
            <button id="lgpd-recusar" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200 text-slate-600 font-bold text-sm hover:bg-slate-50 transition">
                Apenas Essenciais
            </button>
            <button id="lgpd-aceitar" class="flex-1 px-4 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm shadow-md shadow-amber-500/20 transition">
                Aceitar Tudo
            </button>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const banner = document.getElementById('lgpd-banner');
            const btnAceitar = document.getElementById('lgpd-aceitar');
            const btnRecusar = document.getElementById('lgpd-recusar');

            // Verifica se o utilizador já respondeu antes
            if (!localStorage.getItem('stl_lgpd_consent')) {
                // Animação de entrada suave após 1 segundo do site carregar
                setTimeout(() => {
                    banner.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
                }, 1000);
            }

            function fecharBanner(resposta) {
                // Salva a decisão no navegador do turista
                localStorage.setItem('stl_lgpd_consent', resposta);
                
                // Se ele aceitou, podemos disparar um evento pro Google Analytics saber!
                if(resposta === 'aceitou' && typeof gtag === 'function') {
                    gtag('event', 'consentimento_lgpd', { 'status': 'aceito' });
                }

                // Animação de saída
                banner.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
            }

            btnAceitar.addEventListener('click', () => fecharBanner('aceitou'));
            btnRecusar.addEventListener('click', () => fecharBanner('recusou'));
        });
    </script>
</body>
</html>
