<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title><%= empresa.nome %> - Portal São Thomé das Letras</title>
    
    <link rel="stylesheet" href="/css/style.css">

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-BDTY71XR8Q');
    </script>
</head>
<body>

    <header>
        <a href="/">Voltar para a Home</a>
    </header>

    <main class="detalhes-empresa">
        <h1><%= empresa.nome %></h1>
        <p class="categoria">Categoria: <%= empresa.categoria %></p>
        
        <div class="informacoes">
            <p><strong>Endereço:</strong> <%= empresa.endereco %></p>
            <p><strong>Telefone:</strong> <%= empresa.telefone %></p>
            <p><strong>Descrição:</strong> <%= empresa.descricao %></p>
        </div>
        
        <a href="https://wa.me/<%= empresa.whatsapp %>" class="btn-whatsapp">Entrar em Contato</a>
    </main>

    <footer>
        <p>&copy; 2026 Portal São Thomé das Letras. Desenvolvido por Resultados Online.</p>
    </footer>

</body>
</html>