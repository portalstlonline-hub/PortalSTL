<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title><%= empresa.nome %> - Portal São Thomé das Letras</title>
    <meta name="description" content="<%= empresa.descricao ? empresa.descricao.substring(0, 160) : 'Confira os detalhes de ' + empresa.nome + ' em São Thomé das Letras.' %>">
    
    <meta property="og:title" content="<%= empresa.nome %> | Portal STL">
    <meta property="og:description" content="Descubra tudo sobre este local em São Thomé das Letras.">
    <meta property="og:image" content="<%= empresa.imagem || '/img/default-share.jpg' %>">
    <meta property="og:type" content="website">

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BDTY71XR8Q');
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-100">
        <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/" class="text-xl font-black tracking-tighter text-slate-900">
                PORTAL<span class="text-amber-500">STL</span>
            </a>
            <a href="/explorar" class="text-sm font-bold text-slate-600 hover:text-amber-600 transition">
                <i class="fas fa-search mr-1"></i> Explorar
            </a>
        </div>
    </nav>

    <div class="relative h-[40vh] md:h-[60vh] w-full overflow-hidden bg-slate-200">
        <% if(empresa.imagem) { %>
            <img src="<%= empresa.imagem %>" alt="<%= empresa.nome %>" class="w-full h-full object-cover">
        <% } else { %>
            <div class="w-full h-full flex items-center justify-center bg-slate-300 text-slate-400">
                <i class="fas fa-image text-6xl"></i>
            </div>
        <% } %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-6 md:p-12">
            <div class="max-w-6xl mx-auto">
                <h1 class="text-3xl md:text-5xl font-black text-white drop-shadow-lg"><%= empresa.nome %></h1>
                <div class="flex flex-wrap gap-3 mt-4">
                    <span class="bg-amber-500 text-white text-xs font-extrabold px-3 py-1 rounded-full uppercase tracking-wider shadow-lg">
                        <%= empresa.categoria_id %>
                    </span>
                    <% if(empresa.plano_id === 3) { %>
                        <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-3 py-1 rounded-full border border-white/30">
                            <i class="fas fa-crown text-amber-300 mr-1"></i> Destaque da Cidade
                        </span>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <main class="max-w-6xl mx-auto px-4 py-10">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            
            <div class="lg:col-span-2 space-y-8">
                
                <section class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100">
                    <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
                        <i class="fas fa-align-left text-amber-500"></i> Sobre o local
                    </h2>
                    <p class="text-slate-600 leading-relaxed whitespace-pre-line">
                        <%= empresa.descricao || 'Este local ainda não possui uma descrição detalhada.' %>
                    </p>
                </section>

                <!-- EXCLUSIVO PARA VITRINE PREMIUM OU SUPERIOR (plano_id >= 2) -->
                <% if(empresa.plano_id >= 2 && empresa.galeria) { 
                    const imagens = JSON.parse(empresa.galeria); 
                    if(imagens.length > 0) { %>
                    <section>
                        <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
                            <i class="fas fa-th-large text-amber-500"></i> Galeria de Fotos
                        </h2>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            <% imagens.slice(0, 6).forEach(img => { %>
                                <div class="aspect-square rounded-2xl overflow-hidden shadow-sm hover:scale-[1.02] transition duration-300 cursor-pointer">
                                    <img src="<%= img %>" class="w-full h-full object-cover">
                                </div>
                            <% }) %>
                        </div>
                    </section>
                <% } } %>

                <% if(empresa.video_url) { %>
                    <section class="bg-slate-900 p-2 rounded-3xl overflow-hidden shadow-2xl">
                        <div class="aspect-video">
                            <iframe class="w-full h-full" src="<%= empresa.video_url.replace('watch?v=', 'embed/') %>" frameborder="0" allowfullscreen></iframe>
                        </div>
                    </section>
                <% } %>
            </div>

            <div class="space-y-6">
                
                <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100 sticky top-24">
                    <h3 class="text-lg font-bold mb-6 text-slate-800">Informações e Reservas</h3>
                    
                    <div class="space-y-4">
                        <% if(empresa.whatsapp) { %>
                            <a href="https://wa.me/55<%= empresa.whatsapp.replace(/\D/g,'') %>" target="_blank" 
                               class="flex items-center justify-center gap-2 w-full bg-green-500 hover:bg-green-600 text-white font-black py-4 rounded-2xl transition shadow-lg shadow-green-200">
                                <i class="fab fa-whatsapp text-xl"></i> CHAMAR NO WHATSAPP
                            </a>
                        <% } %>

                        <% if(empresa.instagram) { %>
                            <a href="https://instagram.com/<%= empresa.instagram.replace('@','') %>" target="_blank" 
                               class="flex items-center justify-center gap-2 w-full bg-gradient-to-tr from-yellow-400 via-red-500 to-purple-600 text-white font-bold py-3 rounded-2xl transition">
                                <i class="fab fa-instagram"></i> Ver Instagram
                            </a>
                        <% } %>

                        <div class="pt-6 space-y-4 border-t border-slate-100 mt-6">
                            <% if(empresa.endereco) { %>
                                <div class="flex gap-3">
                                    <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center text-slate-500 shrink-0">
                                        <i class="fas fa-map-marker-alt"></i>
                                    </div>
                                    <div class="text-sm">
                                        <p class="font-bold text-slate-700">Endereço</p>
                                        <p class="text-slate-500"><%= empresa.endereco %></p>
                                        <% if(empresa.link_maps) { %>
                                            <a href="<%= empresa.link_maps %>" target="_blank" class="text-amber-600 font-bold text-xs hover:underline mt-1 inline-block">Abrir no GPS</a>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 rounded-3xl p-6 text-white overflow-hidden relative group">
                    <div class="relative z-10">
                        <p class="text-xs font-bold text-amber-400 uppercase tracking-widest mb-1">Anuncie aqui</p>
                        <h4 class="text-lg font-black leading-tight">Quer sua empresa em destaque?</h4>
                        <a href="/#anunciar" class="inline-block mt-4 text-sm font-bold bg-white text-slate-900 px-4 py-2 rounded-full hover:bg-amber-500 hover:text-white transition">Saiba mais</a>
                    </div>
                    <i class="fas fa-rocket absolute -bottom-4 -right-4 text-7xl text-white/5 -rotate-12 group-hover:scale-110 transition"></i>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-white border-t border-slate-100 py-10 mt-20">
        <div class="max-w-6xl mx-auto px-4 text-center">
            <p class="text-slate-400 text-sm font-medium">© 2026 Portal São Thomé das Letras. Desenvolvido por Resultados Online.</p>
        </div>
    </footer>

</body>
</html>
