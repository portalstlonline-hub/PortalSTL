<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO DINÂMICO -->
    <title><%= empresa.nome %> - Portal São Thomé das Letras</title>
    <meta name="description" content="<%= empresa.descricao ? empresa.descricao.substring(0, 160) : 'Confira os detalhes de ' + empresa.nome + ' em São Thomé das Letras.' %>">
    
    <!-- OPEN GRAPH (Para partilhas em Redes Sociais/WhatsApp) -->
    <meta property="og:title" content="<%= empresa.nome %> | Portal STL">
    <meta property="og:description" content="<%= empresa.descricao ? empresa.descricao.substring(0, 160) : 'Descubra tudo sobre este local em São Thomé das Letras.' %>">
    
    <!-- 🚨 O SEGREDO DO WHATSAPP (URL ABSOLUTA PARA A CAPA DA EMPRESA) 🚨 -->
    <meta property="og:image" content="https://portalsaothomedasletras.com.br<%= empresa.imagem ? empresa.imagem : '/uploads/capa-compartilhamento.png' %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:type" content="website">

    <!-- 🚨 FAVICON 🚨 -->
    <link rel="icon" type="image/png" href="/uploads/logo%20favicon.png">

    <!-- 🕵️‍♂️ GOOGLE ANALYTICS 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BDTY71XR8Q');
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <!-- HEADER / NAV -->
    <nav class="bg-white/95 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 shadow-sm transition-all duration-300">
        <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
            <!-- 🚨 A SUA NOVA LOGOMARCA 🚨 -->
            <a href="/" class="flex items-center">
                <img src="/uploads/PORTAL STL logo.png" alt="Portal STL" class="h-9 md:h-11 w-auto object-contain">
            </a>
            <div class="flex items-center gap-4">
                <a href="/explorar" class="text-sm font-bold text-slate-600 hover:text-amber-600 transition flex items-center gap-1">
                    <i class="fas fa-search"></i> Explorar
                </a>
                <!-- 🚨 BOTÃO ANUNCIE PRETO 🚨 -->
                <a href="/#anunciar" class="bg-slate-900 hover:bg-black text-white text-xs md:text-sm font-bold px-5 md:px-6 py-2 md:py-2.5 rounded-full transition shadow-sm whitespace-nowrap">
                    Anuncie
                </a>
            </div>
        </div>
    </nav>

    <!-- BANNER PRINCIPAL / CAPA (PROPORÇÃO FACEBOOK: 820x312) -->
    <div class="relative w-full aspect-[16/9] md:aspect-[820/312] bg-slate-900 overflow-hidden flex justify-center items-center">
        <% if(empresa.imagem) { %>
            <!-- object-contain agora ativado para mobile e desktop: a arte nunca será cortada! -->
            <img src="<%= empresa.imagem %>" alt="<%= empresa.nome %>" class="w-full h-full object-contain opacity-95">
        <% } else { %>
            <div class="w-full h-full flex items-center justify-center bg-slate-800 text-slate-500">
                <i class="fas fa-image text-6xl"></i>
            </div>
        <% } %>
        
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-full p-4 md:p-10 pointer-events-none">
            <div class="max-w-6xl mx-auto pointer-events-auto">
                <h1 class="text-3xl md:text-5xl lg:text-6xl font-black text-white drop-shadow-lg leading-tight"><%= empresa.nome %></h1>

                <div class="flex flex-wrap gap-3 mt-3">
                    <span class="bg-amber-500 text-white text-xs font-extrabold px-3 py-1.5 rounded-full uppercase tracking-wider shadow-lg">
                        <%= empresa.categoria_nome || 'Local' %>
                    </span>
                    <% if(empresa.plano_id === 3) { %>
                        <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 rounded-full border border-white/30 flex items-center gap-1">
                            <i class="fas fa-crown text-amber-300"></i> Destaque da Cidade
                        </span>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- CONTEÚDO -->
    <main class="max-w-6xl mx-auto px-4 py-10">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            
            <!-- COLUNA ESQUERDA: INFO -->
            <div class="lg:col-span-2 space-y-8">
                
                <!-- Descrição -->
                <section class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100">
                    <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
                        <i class="fas fa-align-left text-amber-500"></i> Sobre
                    </h2>
                    <p class="text-slate-600 leading-relaxed whitespace-pre-line text-lg">
                        <%= empresa.descricao || 'Este local ainda não possui uma descrição detalhada.' %>
                    </p>
                </section>

                <!-- EXCLUSIVO PARA VITRINE PREMIUM OU SUPERIOR (plano_id >= 2) -->
                <% if(empresa.plano_id >= 2 && empresa.galeria) { 
                    const imagens = JSON.parse(empresa.galeria); 
                    if(imagens.length > 0) { %>
                    <section>
                        <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
                            <i class="fas fa-camera-retro text-amber-500"></i> Galeria de Fotos
                        </h2>
                        <!-- Suporte para até 6 imagens em grid responsivo com função de clique -->
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            <% imagens.slice(0, 6).forEach(img => { %>
                                <div class="aspect-square rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-md hover:scale-[1.02] transition duration-300 cursor-pointer" onclick="abrirLightbox('<%= img %>')">
                                    <img src="<%= img %>" class="w-full h-full object-cover hover:opacity-90 transition">
                                </div>
                            <% }) %>
                        </div>
                    </section>
                <% } } %>

                <!-- 🚨 VÍDEO CAMALEÃO (YouTube, FB, Insta, Vimeo) 🚨 -->
                <% if(empresa.video_url) { 
                    let rawUrl = empresa.video_url.trim();
                    let finalUrl = rawUrl;
                    
                    if (rawUrl.includes('youtube.com/watch?v=')) {
                        finalUrl = rawUrl.replace('watch?v=', 'embed/');
                        if(finalUrl.includes('&')) finalUrl = finalUrl.split('&')[0]; // Remove parâmetros extras
                    } else if (rawUrl.includes('youtu.be/')) {
                        let yId = rawUrl.split('youtu.be/')[1].split('?')[0];
                        finalUrl = 'https://www.youtube.com/embed/' + yId;
                    } else if (rawUrl.includes('instagram.com/p/') || rawUrl.includes('instagram.com/reel/')) {
                        let cleanUrl = rawUrl.split('?')[0];
                        if(!cleanUrl.endsWith('/')) cleanUrl += '/';
                        finalUrl = cleanUrl + 'embed';
                    } else if (rawUrl.includes('facebook.com')) {
                        finalUrl = 'https://www.facebook.com/plugins/video.php?href=' + encodeURIComponent(rawUrl) + '&show_text=false';
                    } else if (rawUrl.includes('vimeo.com/')) {
                        let vId = rawUrl.split('vimeo.com/')[1].split('?')[0];
                        finalUrl = 'https://player.vimeo.com/video/' + vId;
                    }
                %>
                    <section class="bg-slate-900 p-2 rounded-3xl overflow-hidden shadow-xl border border-slate-800">
                        <!-- Fundo preto e centralização para acomodar vídeos verticais (Insta/Reels) sem distorcer -->
                        <div class="aspect-video rounded-2xl overflow-hidden bg-black flex justify-center items-center">
                            <iframe class="w-full h-full" src="<%= finalUrl %>" frameborder="0" scrolling="no" allowtransparency="true" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" allowfullscreen></iframe>
                        </div>
                    </section>
                <% } %>

            </div>

            <!-- COLUNA DIREITA: SIDEBAR/CONTATO -->
            <div class="space-y-6">
                
                <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100">
                    <h3 class="text-lg font-bold mb-6 text-slate-800 flex items-center gap-2">
                        <i class="far fa-address-card text-amber-500"></i> Contatos
                    </h3>
                    
                    <div class="space-y-4">
                        <!-- WhatsApp Premium -->
                        <% if(empresa.whatsapp) { %>
                            <a href="https://wa.me/55<%= empresa.whatsapp.replace(/\D/g,'') %>?text=Ol%C3%A1!%20Vi%20o%20seu%20an%C3%BAncio%20no%20Portal%20STL." target="_blank" 
                               class="flex items-center justify-center gap-2 w-full bg-[#25D366] hover:bg-[#1da851] text-white font-black py-4 rounded-2xl transition shadow-lg shadow-green-200 text-lg">
                                <i class="fab fa-whatsapp text-2xl"></i> WHATSAPP
                            </a>
                        <% } %>

                        <!-- Redes Sociais: Insta & Facebook Lado a Lado -->
                        <div class="grid grid-cols-2 gap-3 mt-4">
                            <% if(empresa.instagram) { %>
                                <a href="https://instagram.com/<%= empresa.instagram.replace('@','') %>" target="_blank" 
                                   class="flex items-center justify-center gap-2 w-full bg-slate-50 hover:bg-pink-50 text-slate-700 hover:text-pink-600 font-bold py-3 rounded-xl border border-slate-200 hover:border-pink-200 transition text-sm">
                                    <i class="fab fa-instagram text-lg"></i> Instagram
                                </a>
                            <% } %>

                            <% if(empresa.facebook) { %>
                                <a href="<%= empresa.facebook.startsWith('http') ? empresa.facebook : 'https://' + empresa.facebook %>" target="_blank" 
                                   class="flex items-center justify-center gap-2 w-full bg-slate-50 hover:bg-blue-50 text-slate-700 hover:text-blue-600 font-bold py-3 rounded-xl border border-slate-200 hover:border-blue-200 transition text-sm">
                                    <i class="fab fa-facebook text-lg"></i> Facebook
                                </a>
                            <% } %>
                        </div>

                        <!-- Site Oficial -->
                        <% if(empresa.site) { %>
                            <a href="<%= empresa.site.startsWith('http') ? empresa.site : 'https://' + empresa.site %>" target="_blank" 
                               class="flex items-center justify-center gap-2 w-full bg-slate-100 hover:bg-amber-100 text-slate-700 hover:text-amber-700 font-bold py-3 rounded-xl transition text-sm mt-2">
                                <i class="fas fa-globe text-lg"></i> Visitar Site Oficial
                            </a>
                        <% } %>
                    </div>
                </div>

                <!-- CARTÃO DE LOCALIZAÇÃO (MAPS DIFERENCIADO) -->
                <% if(empresa.endereco || empresa.link_maps) { %>
                <div class="bg-slate-900 rounded-3xl p-6 shadow-xl text-white relative overflow-hidden">
                    <i class="fas fa-map-marked-alt absolute -bottom-4 -right-4 text-7xl text-slate-800 opacity-50 -rotate-12"></i>
                    
                    <h3 class="text-lg font-black text-white mb-4 relative flex items-center gap-2">
                        <i class="fas fa-location-dot text-amber-500"></i> Como Chegar
                    </h3>
                    
                    <div class="relative mb-6">
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-1">Endereço Registrado</p>
                        <p class="text-sm font-medium text-slate-200 leading-relaxed"><%= empresa.endereco || 'São Thomé das Letras, MG' %></p>
                    </div>

                    <% if(empresa.link_maps) { %>
                        <a href="<%= empresa.link_maps %>" target="_blank" class="w-full bg-white hover:bg-amber-500 text-slate-900 hover:text-white font-black py-3.5 rounded-xl transition flex items-center justify-center gap-2 relative shadow-md">
                            <i class="fas fa-route"></i> Abrir no Google Maps
                        </a>
                    <% } %>
                </div>
                <% } %>

                <!-- 🚨 CARTÃO DE COMPARTILHAMENTO (Boca a Boca Digital) 🚨 -->
                <div class="bg-white rounded-3xl p-6 shadow-xl border border-slate-100 mt-6">
                    <h3 class="text-lg font-bold mb-4 text-slate-800 flex items-center gap-2">
                        <i class="fas fa-share-nodes text-amber-500"></i> Compartilhar Local
                    </h3>
                    <div class="flex gap-3">
                        <!-- WhatsApp -->
                        <button onclick="compartilharWhatsApp()" class="flex-1 bg-[#25D366] hover:bg-[#1da851] text-white py-3.5 rounded-xl transition shadow-md flex items-center justify-center gap-2" title="Compartilhar no WhatsApp">
                            <i class="fab fa-whatsapp text-xl"></i>
                        </button>
                        <!-- Facebook -->
                        <button onclick="compartilharFacebook()" class="flex-1 bg-[#1877F2] hover:bg-[#166fe5] text-white py-3.5 rounded-xl transition shadow-md flex items-center justify-center gap-2" title="Compartilhar no Facebook">
                            <i class="fab fa-facebook-f text-xl"></i>
                        </button>
                        <!-- Copiar Link -->
                        <button onclick="copiarLink()" id="btnCopiar" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 py-3.5 rounded-xl transition shadow-sm flex items-center justify-center gap-2" title="Copiar Link">
                            <i class="fas fa-link text-xl"></i>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <footer class="bg-white border-t border-slate-100 py-10 mt-20">
        <div class="max-w-6xl mx-auto px-4 text-center flex flex-col items-center">
            <!-- 🚨 Rodapé com Logo em vez de Texto (Opcional, mas dá mais autoridade) 🚨 -->
            <img src="/uploads/PORTAL STL logo.png" alt="Portal STL" class="h-8 md:h-10 w-auto object-contain grayscale opacity-40 mb-3 hover:grayscale-0 hover:opacity-100 transition duration-300">
            <p class="text-slate-400 text-sm font-medium">© 2026. Desenvolvido com <i class="fas fa-heart text-red-400 mx-1"></i> por Resultados Online.</p>
        </div>
    </footer>

    <!-- MODAL DO LIGHTBOX (AMPLIAÇÃO DE FOTOS) -->
    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex justify-center items-center p-4 backdrop-blur-sm transition-opacity" onclick="fecharLightbox()">
        <button class="absolute top-4 right-4 md:top-8 md:right-8 text-white hover:text-amber-500 text-4xl font-bold transition focus:outline-none" aria-label="Fechar">&times;</button>
        <img id="lightbox-img" src="" class="max-w-full max-h-[90vh] object-contain rounded-xl shadow-2xl" onclick="event.stopPropagation()">
    </div>

    <!-- SCRIPT DO LIGHTBOX -->
    <script>
        function abrirLightbox(src) {
            document.getElementById('lightbox-img').src = src;
            document.getElementById('lightbox').classList.remove('hidden');
            document.body.style.overflow = 'hidden'; // Evita que a página faça scroll no fundo
        }

        function fecharLightbox() {
            document.getElementById('lightbox').classList.add('hidden');
            document.body.style.overflow = 'auto'; // Restaura o scroll
        }
        
        // Fecha o lightbox ao pressionar a tecla ESC
        document.addEventListener('keydown', function(event){
            if(event.key === "Escape") fecharLightbox();
        });

        // 🚨 FUNÇÕES MÁGICAS DE COMPARTILHAMENTO 🚨
        function compartilharWhatsApp() {
            const url = encodeURIComponent(window.location.href);
            // Mensagem persuasiva já pronta para o turista
            const texto = encodeURIComponent(`Olha esse lugar incrível que encontrei no Portal STL: <%= empresa.nome %>\n\n`);
            window.open(`https://api.whatsapp.com/send?text=${texto}${url}`, '_blank');
        }

        function compartilharFacebook() {
            const url = encodeURIComponent(window.location.href);
            window.open(`https://www.facebook.com/sharer/sharer.php?u=${url}`, '_blank');
        }

        function copiarLink() {
            // Método à prova de falhas para garantir a cópia em qualquer celular
            const tempInput = document.createElement("input");
            tempInput.value = window.location.href;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);
            
            // Efeito visual (UX) mudando o ícone para um Visto Verde
            const btn = document.getElementById('btnCopiar');
            const iconOriginal = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check text-xl text-emerald-500"></i>';
            setTimeout(() => {
                btn.innerHTML = iconOriginal;
            }, 2000); // Volta ao normal após 2 segundos
        }
    </script>

</body>
</html>
