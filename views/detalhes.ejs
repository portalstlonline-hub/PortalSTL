<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <% 
        let ogImage = 'https://portalsaothomedasletras.com.br/uploads/capa-compartilhamento.png';
        if (empresa.imagem) {
            ogImage = empresa.imagem.startsWith('http') ? empresa.imagem : 'https://portalsaothomedasletras.com.br' + empresa.imagem;
        }
        
        // Determina o tipo do arquivo de forma inteligente
        let ogType = 'image/jpeg';
        if (ogImage.toLowerCase().endsWith('.png')) ogType = 'image/png';
        if (ogImage.toLowerCase().endsWith('.webp')) ogType = 'image/webp';
    %>
    <meta property="og:title" content="<%= empresa.nome %> | Portal STL">
    <meta property="og:description" content="<%= empresa.descricao ? empresa.descricao.substring(0, 160).replace(/"/g, '') : 'Descubra tudo sobre este local em São Thomé das Letras.' %>">
    <meta property="og:url" content="https://portalsaothomedasletras.com.br/<%= empresa.slug %>">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:image:secure_url" content="<%= ogImage %>">
    <meta property="og:image:type" content="<%= ogType %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:type" content="website">

    <title><%= empresa.nome %> - Portal São Thomé das Letras</title>
    <meta name="description" content="<%= empresa.descricao ? empresa.descricao.substring(0, 160) : 'Confira os detalhes de ' + empresa.nome + ' em São Thomé das Letras.' %>">
    
    <link rel="icon" type="image/png" href="/uploads/favicon.png">

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BDTY71XR8Q');
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
