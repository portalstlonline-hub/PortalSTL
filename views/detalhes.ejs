<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <% 
        let ogImage = 'https://portalsaothomedasletras.com.br/uploads/capa-compartilhamento.png';
        if (empresa.imagem) {
            ogImage = empresa.imagem;
            if (!ogImage.startsWith('http')) {
                ogImage = 'https://portalsaothomedasletras.com.br' + ogImage;
            }
            // Força a imagem a ser segura e formatada perfeitamente para o Facebook
            if (ogImage.includes('cloudinary.com') && ogImage.includes('/upload/')) {
                if(!ogImage.includes('w_1200')) {
                    ogImage = ogImage.replace('/upload/', '/upload/w_1200,h_630,c_fill,f_jpg,q_80/');
                }
            }
        }
        ogImage = ogImage.replace('http://', 'https://');
        
        let ogType = 'image/jpeg';
        let cleanDesc = empresa.descricao ? empresa.descricao.substring(0, 160).replace(/"/g, '&quot;').replace(/\n/g, ' ').trim() : 'Descubra tudo sobre este local em São Thomé das Letras.';
    %>
    
    <meta name="robots" content="index, follow, max-image-preview:large">
    <meta property="og:title" content="<%= empresa.nome %> | Portal STL">
    <meta property="og:description" content="<%= cleanDesc %>">
    <meta property="og:url" content="https://portalsaothomedasletras.com.br/<%= empresa.slug %>">
    <meta property="og:image" itemprop="image" content="<%= ogImage %>">
    <meta property="og:image:secure_url" content="<%= ogImage %>">
    <meta property="og:image:type" content="<%= ogType %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:type" content="website">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= empresa.nome %> | Portal STL">
    <meta name="twitter:description" content="<%= cleanDesc %>">
    <meta name="twitter:image" content="<%= ogImage %>">

    <title><%= empresa.nome %> - Portal São Thomé das Letras</title>
    <meta name="description" content="<%= cleanDesc %>">
    <link rel="icon" type="image/png" href="/uploads/favicon.png">

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BDTY71XR8Q');
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <nav class="bg-white/95 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 shadow-sm transition-all duration-300">
        <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/" class="flex items-center">
                <img src="/uploads/portallogomarca.png" alt="Portal STL" class="h-9 md:h-11 w-auto object-contain">
            </a>
            <div class="flex items-center gap-4">
                <a href="/explorar" class="text-sm font-bold text-slate-600 hover:text-amber-600 transition flex items-center gap-1">
                    <i class="fas fa-search"></i> Explorar
                </a>
                <a href="/#anunciar" class="bg-slate-900 hover:bg-black text-white text-xs md:text-sm font-bold px-5 md:px-6 py-2 md:py-2.5 rounded-full transition shadow-sm whitespace-nowrap">
                    Anuncie
                </a>
            </div>
        </div>
    </nav>

    <div class="relative w-full aspect-[16/9] md:aspect-[820/312] bg-slate-900 overflow-hidden flex justify-center items-center border-b border-slate-200">
        <% if(empresa.imagem) { %>
            <img src="<%= empresa.imagem %>" alt="<%= empresa.nome %>" class="w-full h-full object-contain">
        <% } else { %>
            <div class="w-full h-full flex items-center justify-center bg-slate-800 text-slate-500">
                <i class="fas fa-image text-6xl"></i>
            </div>
        <% } %>
    </div>

    <main class="max-w-6xl mx-auto px-4 py-8 md:py-10">
        
        <div class="mb-8 border-b border-slate-200 pb-6">
            <div class="flex flex-wrap items-center gap-3 mb-3">
                <span class="bg-amber-500 text-white text-xs font-extrabold px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
                    <%= empresa.categoria_nome || 'Local' %>
                </span>
                <% if(empresa.plano_id === 3) { %>
                    <span class="bg-slate-900 text-amber-400 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm flex items-center gap-1">
                        <i class="fas fa-crown"></i> Destaque da Cidade
                    </span>
                <% } %>
            </div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 leading-tight tracking-tight"><%= empresa.nome %></h1>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            
            <div class="lg:col-span-2 space-y-8">
                
                <section class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100">
                    <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
                        <i class="fas fa-align-left text-amber-500"></i> Sobre
                    </h2>
                    <p class="text-slate-600 leading-relaxed whitespace-pre-line text-lg">
                        <%= empresa.descricao || 'Este local ainda não possui uma descrição detalhada.' %>
                    </p>
                </section>

                <% if(empresa.plano_id >= 2 && empresa.galeria) { 
                    const imagens = JSON.parse(empresa.galeria); 
                    if(imagens.length > 0) { %>
                    <section>
                        <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
                            <i class="fas fa-camera-retro text-amber-500"></i> Galeria de Fotos
                        </h2>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            <% imagens.slice(0, 6).forEach(img => { %>
                                <div class="aspect-square rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-md hover:scale-[1.02] transition duration-300 cursor-pointer" onclick="abrirLightbox('<%= img %>')">
                                    <img src="<%= img %>" class="w-full h-full object-cover hover:opacity-90 transition">
                                </div>
                            <% }) %>
                        </div>
                    </section>
                <% } } %>

                <% if(empresa.video_url) { 
                    let rawUrl = empresa.video_url.trim();
                    let finalUrl = rawUrl;
                    
                    if (rawUrl.includes('youtube.com/watch?v=')) {
                        finalUrl = rawUrl.replace('watch?v=', 'embed/');
                        if(finalUrl.includes('&')) finalUrl = finalUrl.split('&')[0];
                    } else if (rawUrl.includes('youtu.be/')) {
                        let yId = rawUrl.split('youtu.be/')[1].split('?')[0];
                        finalUrl = 'https://www.youtube.com/embed/' + yId;
                    } else if (rawUrl.includes('instagram.com/p/') || rawUrl.includes('instagram.com/reel/')) {
                        let cleanUrl = rawUrl.split('?')[0];
                        if(!cleanUrl.endsWith('/')) cleanUrl += '/';
                        finalUrl = cleanUrl + 'embed';
                    } else if (rawUrl.includes('facebook.com')) {
                        finalUrl = 'https://www.facebook.com/plugins/video.php?href=' + encodeURIComponent(rawUrl) + '&show_text=false';
                    } else if (rawUrl.includes('vimeo.com/')) {
                        let vId = rawUrl.split('vimeo.com/')[1].split('?')[0];
                        finalUrl = 'https://player.vimeo.com/video/' + vId;
                    }
                %>
                    <section class="bg-slate-900 p-2 rounded-3xl overflow-hidden shadow-xl border border-slate-800">
                        <div class="aspect-video rounded-2xl overflow-hidden bg-black flex justify-center items-center">
                            <iframe class="w-full h-full" src="<%= finalUrl %>" frameborder="0" scrolling="no" allowtransparency="true" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" allowfullscreen></iframe>
                        </div>
                    </section>
                <% } %>

            </div>

            <div class="space-y-6">
                
                <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100">
                    <h3 class="text-lg font-bold mb-6 text-slate-800 flex items-center gap-2">
                        <i class="far fa-address-card text-amber-500"></i> Contatos
                    </h3>
                    
                    <% 
                        function prepararLink(url, plataforma) {
                            if (!url) return '#';
                            let limpo = url.trim();
                            if (/^https?:\/\//i.test(limpo)) return limpo;
                            
                            if (plataforma === 'instagram') {
                                if (limpo.toLowerCase().includes('instagram.com')) return 'https://' + limpo;
                                return 'https://instagram.com/' + limpo.replace('@', '');
                            }
                            if (plataforma === 'facebook') {
                                if (limpo.toLowerCase().includes('facebook.com')) return 'https://' + limpo;
                                return 'https://www.facebook.com/' + limpo;
                            }
                            return 'https://' + limpo;
                        }
                    %>

                    <div class="space-y-4">
                        <% if(empresa.whatsapp) { %>
                            <a href="https://wa.me/55<%= empresa.whatsapp.replace(/\D/g,'') %>?text=Ol%C3%A1!%20Vi%20o%20seu%20an%C3%BAncio%20no%20Portal%20STL." target="_blank" 
                               onclick="gtag('event', 'clique_whatsapp', { 'nome_empresa': '<%= empresa.nome %>', 'categoria': '<%= empresa.categoria_nome %>' }); registrarClique('<%= empresa.slug %>', 'whatsapp');"
                               class="flex items-center justify-center gap-2 w-full bg-[#25D366] hover:bg-[#1da851] text-white font-black py-4 rounded-2xl transition shadow-lg shadow-green-200 text-lg">
                                <i class="fab fa-whatsapp text-2xl"></i> WHATSAPP
                            </a>
                        <% } %>

                        <div class="grid grid-cols-2 gap-3 mt-4">
                            <% if(empresa.instagram) { %>
                                <a href="<%= prepararLink(empresa.instagram, 'instagram') %>" target="_blank" 
                                   onclick="gtag('event', 'clique_instagram', { 'nome_empresa': '<%= empresa.nome %>' }); registrarClique('<%= empresa.slug %>', 'social');"
                                   class="flex items-center justify-center gap-2 w-full bg-slate-50 hover:bg-pink-50 text-slate-700 hover:text-pink-600 font-bold py-3 rounded-xl border border-slate-200 hover:border-pink-200 transition text-sm">
                                    <i class="fab fa-instagram text-lg"></i> Instagram
                                </a>
                            <% } %>

                            <% if(empresa.facebook) { %>
                                <a href="<%= prepararLink(empresa.facebook, 'facebook') %>" target="_blank" 
                                   onclick="gtag('event', 'clique_facebook', { 'nome_empresa': '<%= empresa.nome %>' }); registrarClique('<%= empresa.slug %>', 'social');"
                                   class="flex items-center justify-center gap-2 w-full bg-slate-50 hover:bg-blue-50 text-slate-700 hover:text-blue-600 font-bold py-3 rounded-xl border border-slate-200 hover:border-blue-200 transition text-sm">
                                    <i class="fab fa-facebook text-lg"></i> Facebook
                                </a>
                            <% } %>
                        </div>

                        <% if(empresa.site) { %>
                            <a href="<%= prepararLink(empresa.site, 'site') %>" target="_blank" 
                               onclick="gtag('event', 'clique_site', { 'nome_empresa': '<%= empresa.nome %>' }); registrarClique('<%= empresa.slug %>', 'social');"
                               class="flex items-center justify-center gap-2 w-full bg-slate-100 hover:bg-amber-100 text-slate-700 hover:text-amber-700 font-bold py-3 rounded-xl transition text-sm mt-2">
                                <i class="fas fa-globe text-lg"></i> Visitar Site Oficial
                            </a>
                        <% } %>
                    </div>
                </div>

                <% if(empresa.endereco || empresa.link_maps) { %>
                <div class="bg-slate-900 rounded-3xl p-6 shadow-xl text-white relative overflow-hidden">
                    <i class="fas fa-map-marked-alt absolute -bottom-4 -right-4 text-7xl text-slate-800 opacity-50 -rotate-12"></i>
                    
                    <h3 class="text-lg font-black text-white mb-4 relative flex items-center gap-2">
                        <i class="fas fa-location-dot text-amber-500"></i> Como Chegar
                    </h3>
                    
                    <div class="relative mb-6">
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-1">Endereço Registrado</p>
                        <p class="text-sm font-medium text-slate-200 leading-relaxed"><%= empresa.endereco || 'São Thomé das Letras, MG' %></p>
                    </div>

                    <% if(empresa.link_maps) { %>
                        <a href="<%= empresa.link_maps %>" target="_blank" 
                           onclick="gtag('event', 'clique_mapa', { 'nome_empresa': '<%= empresa.nome %>' }); registrarClique('<%= empresa.slug %>', 'mapa');"
                           class="w-full bg-white hover:bg-amber-500 text-slate-900 hover:text-white font-black py-3.5 rounded-xl transition flex items-center justify-center gap-2 relative shadow-md">
                            <i class="fas fa-route"></i> Abrir no Google Maps
                        </a>
                    <% } %>
                </div>
                <% } %>

                <div class="bg-white rounded-3xl p-6 shadow-xl border border-slate-100 mt-6">
                    <h3 class="text-lg font-bold mb-4 text-slate-800 flex items-center gap-2">
                        <i class="fas fa-share-nodes text-amber-500"></i> Compartilhar Local
                    </h3>
                    <div class="flex gap-3">
                        <button onclick="compartilharWhatsApp(); registrarClique('<%= empresa.slug %>', 'share');" class="flex-1 bg-[#25D366] hover:bg-[#1da851] text-white py-3.5 rounded-xl transition shadow-md flex items-center justify-center gap-2" title="Compartilhar no WhatsApp">
                            <i class="fab fa-whatsapp text-xl"></i>
                        </button>
                        <button onclick="compartilharFacebook(); registrarClique('<%= empresa.slug %>', 'share');" class="flex-1 bg-[#1877F2] hover:bg-[#166fe5] text-white py-3.5 rounded-xl transition shadow-md flex items-center justify-center gap-2" title="Compartilhar no Facebook">
                            <i class="fab fa-facebook-f text-xl"></i>
                        </button>
                        <button onclick="copiarLink(); registrarClique('<%= empresa.slug %>', 'share');" id="btnCopiar" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 py-3.5 rounded-xl transition shadow-sm flex items-center justify-center gap-2" title="Copiar Link">
                            <i class="fas fa-link text-xl"></i>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <footer class="bg-white border-t border-slate-100 py-10 mt-20">
        <div class="max-w-6xl mx-auto px-4 text-center flex flex-col items-center">
            <img src="/uploads/portallogomarca.png" alt="Portal STL" class="h-8 md:h-10 w-auto object-contain grayscale opacity-40 mb-3 hover:grayscale-0 hover:opacity-100 transition duration-300">
            <p class="text-slate-400 text-sm font-medium">© 2026. Desenvolvido com <i class="fas fa-heart text-red-400 mx-1"></i> por Resultados Online.</p>
        </div>
    </footer>

    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex justify-center items-center p-4 backdrop-blur-sm transition-opacity" onclick="fecharLightbox()">
        <button class="absolute top-4 right-4 md:top-8 md:right-8 text-white hover:text-amber-500 text-4xl font-bold transition focus:outline-none" aria-label="Fechar">&times;</button>
        <img id="lightbox-img" src="" class="max-w-full max-h-[90vh] object-contain rounded-xl shadow-2xl" onclick="event.stopPropagation()">
    </div>

    <div id="lgpd-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-8 md:w-[400px] bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 z-[9999] transform translate-y-full opacity-0 transition-all duration-500 flex flex-col pointer-events-none">
        <div class="flex items-start gap-4">
            <div class="text-4xl">🍪</div>
            <div>
                <h4 class="font-black text-slate-900 text-lg mb-1">Privacidade e Cookies</h4>
                <p class="text-sm text-slate-500 leading-relaxed mb-4">
                    Utilizamos cookies para melhorar a sua experiência, personalizar anúncios e gerar estatísticas de acesso. Ao continuar a navegar, você concorda com a nossa política de privacidade.
                </p>
            </div>
        </div>
        <div class="flex gap-3 mt-auto">
            <button id="lgpd-recusar" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200 text-slate-600 font-bold text-sm hover:bg-slate-50 transition">
                Apenas Essenciais
            </button>
            <button id="lgpd-aceitar" class="flex-1 px-4 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm shadow-md shadow-amber-500/20 transition">
                Aceitar Tudo
            </button>
        </div>
    </div>

    <script>
        function abrirLightbox(src) {
            document.getElementById('lightbox-img').src = src;
            document.getElementById('lightbox').classList.remove('hidden');
            document.body.style.overflow = 'hidden'; 
        }

        function fecharLightbox() {
            document.getElementById('lightbox').classList.add('hidden');
            document.body.style.overflow = 'auto'; 
        }
        
        document.addEventListener('keydown', function(event){
            if(event.key === "Escape") fecharLightbox();
        });

        function compartilharWhatsApp() {
            const url = encodeURIComponent(window.location.href);
            const texto = encodeURIComponent(`Olha esse lugar incrível que encontrei no Portal STL: <%= empresa.nome %>\n\n`);
            window.open(`https://api.whatsapp.com/send?text=${texto}${url}`, '_blank');
        }

        function compartilharFacebook() {
            const url = encodeURIComponent(window.location.href);
            window.open(`https://www.facebook.com/sharer/sharer.php?u=${url}`, '_blank');
        }

        function copiarLink() {
            const tempInput = document.createElement("input");
            tempInput.value = window.location.href;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);
            
            const btn = document.getElementById('btnCopiar');
            const iconOriginal = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check text-xl text-emerald-500"></i>';
            setTimeout(() => {
                btn.innerHTML = iconOriginal;
            }, 2000);
        }

        document.addEventListener("DOMContentLoaded", function() {
            const banner = document.getElementById('lgpd-banner');
            const btnAceitar = document.getElementById('lgpd-aceitar');
            const btnRecusar = document.getElementById('lgpd-recusar');

            if (!localStorage.getItem('stl_lgpd_consent')) {
                setTimeout(() => {
                    banner.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
                }, 1000);
            }

            function fecharBanner(resposta) {
                localStorage.setItem('stl_lgpd_consent', resposta);
                if(resposta === 'aceitou' && typeof gtag === 'function') {
                    gtag('event', 'consentimento_lgpd', { 'status': 'aceito' });
                }
                banner.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
            }

            btnAceitar.addEventListener('click', () => fecharBanner('aceitou'));
            btnRecusar.addEventListener('click', () => fecharBanner('recusou'));
        });

        function registrarClique(slug, tipo) {
            fetch(`/api/track/${slug}/${tipo}`, { method: 'POST' })
                .catch(e => console.log('Erro ao rastrear clique no BI:', e));
        }
    </script>

</body>
</html>
