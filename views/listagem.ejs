<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explorar Locais - Portal STL</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SEU_CODIGO_AQUI"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SEU_CODIGO_AQUI');
    </script>
</head>
<body class="bg-gray-50 font-sans text-gray-800 antialiased flex flex-col min-h-screen">

    <!-- CABEÇALHO (NAVBAR) -->
    <nav class="bg-white shadow-sm border-b border-gray-100 relative z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="flex items-center">
                        <img src="/uploads/portallogomarca.png" alt="Portal STL" class="h-10 md:h-12 w-auto object-contain">
                    </a>
                </div>
                <div class="hidden md:flex items-center space-x-6">
                    <a href="/" class="text-gray-500 hover:text-amber-500 font-bold transition">Início</a>
                    <a href="/#anunciar" class="bg-amber-500 hover:bg-amber-600 text-white px-5 py-2 rounded-full font-bold shadow transition">Anunciar</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- BARRA DE FILTROS (Design Clássico Azul Escuro Restaurado) -->
    <div class="bg-slate-900 py-8 shadow-inner">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <form action="/explorar" method="GET" class="flex flex-col md:flex-row gap-4">
                <div class="flex-1">
                    <div class="relative">
                        <i class="fas fa-search absolute left-4 top-3.5 text-gray-400"></i>
                        <input type="text" name="busca" value="<%= buscaAtual || '' %>" placeholder="O que procura?" class="w-full pl-11 pr-4 py-3 rounded-lg border-none focus:ring-2 focus:ring-amber-500 outline-none shadow-sm text-slate-800">
                    </div>
                </div>
                <div class="md:w-64">
                    <select name="categoria" class="w-full px-4 py-3 rounded-lg border-none focus:ring-2 focus:ring-amber-500 outline-none shadow-sm bg-white text-slate-700 cursor-pointer">
                        <option value="">Todas as Categorias</option>
                        <% categorias.forEach(cat => { %>
                            <option value="<%= cat.id %>" <%= categoriaAtual == cat.id ? 'selected' : '' %>><%= cat.nome %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-8 rounded-lg shadow-md transition whitespace-nowrap">
                    Filtrar Resultados
                </button>
            </form>
        </div>
    </div>

    <!-- LISTAGEM DE RESULTADOS -->
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
        
        <div class="mb-8 flex justify-between items-end border-b border-gray-200 pb-4">
            <div>
                <h1 class="text-2xl font-black text-gray-900">Resultados da Busca</h1>
                <p class="text-gray-500 text-sm mt-1">Encontrámos <%= locais ? locais.length : 0 %> locais incríveis para si.</p>
            </div>
        </div>

        <% if (locais && locais.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% locais.forEach(empresa => { %>
                    
                    <% if (empresa.plano_id == 1) { %>
                        <!-- ======================================================== -->
                        <!-- 🥉 CARTÃO PLANO BÁSICO (Sem imagem, contatos diretos) -->
                        <!-- ======================================================== -->
                        <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition duration-300 border border-gray-200 overflow-hidden flex flex-col p-6 relative">
                            
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2 block"><%= empresa.categoria_nome || 'Local' %></span>
                            <h3 class="text-xl font-bold text-gray-900 leading-tight mb-4"><%= empresa.nome %></h3>
                            
                            <!-- Redes e Contatos com GATILHOS DO ANALYTICS BLINDADOS -->
                            <div class="mt-auto pt-4 border-t border-gray-100 flex flex-wrap gap-3 justify-start">
                                
                                <% if (empresa.whatsapp && String(empresa.whatsapp).length > 5) { %>
                                    <a href="https://wa.me/<%= empresa.whatsapp.replace(/\D/g, '') %>" target="_blank"
                                       onclick="gtag('event', 'clique_whatsapp', { 'nome_empresa': '<%= empresa.nome %>', 'categoria': '<%= empresa.categoria_nome %>' });"
                                       class="w-10 h-10 rounded-full bg-green-50 text-green-600 hover:bg-green-500 hover:text-white flex items-center justify-center transition shadow-sm" title="WhatsApp">
                                        <i class="fab fa-whatsapp text-lg"></i>
                                    </a>
                                <% } %>
                                
                                <% if (empresa.instagram && String(empresa.instagram).length > 2) { %>
                                    <a href="https://instagram.com/<%= empresa.instagram.replace('@', '') %>" target="_blank"
                                       onclick="gtag('event', 'clique_instagram', { 'nome_empresa': '<%= empresa.nome %>' });"
                                       class="w-10 h-10 rounded-full bg-pink-50 text-pink-600 hover:bg-pink-500 hover:text-white flex items-center justify-center transition shadow-sm" title="Instagram">
                                        <i class="fab fa-instagram text-lg"></i>
                                    </a>
                                <% } %>
                                
                                <% if (empresa.facebook && String(empresa.facebook).length > 5) { %>
                                    <a href="<%= empresa.facebook %>" target="_blank"
                                       onclick="gtag('event', 'clique_facebook', { 'nome_empresa': '<%= empresa.nome %>' });"
                                       class="w-10 h-10 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white flex items-center justify-center transition shadow-sm" title="Facebook">
                                        <i class="fab fa-facebook-f text-lg"></i>
                                    </a>
                                <% } %>
                                
                                <% if (empresa.link_maps && String(empresa.link_maps).length > 5) { %>
                                    <a href="<%= empresa.link_maps %>" target="_blank"
                                       onclick="gtag('event', 'clique_mapa', { 'nome_empresa': '<%= empresa.nome %>' });"
                                       class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 hover:bg-slate-500 hover:text-white flex items-center justify-center transition shadow-sm" title="Como Chegar">
                                        <i class="fas fa-map-marker-alt text-lg"></i>
                                    </a>
                                <% } %>

                                <% if (empresa.site && String(empresa.site).length > 5) { %>
                                    <a href="<%= empresa.site %>" target="_blank"
                                       onclick="gtag('event', 'clique_site', { 'nome_empresa': '<%= empresa.nome %>' });"
                                       class="w-10 h-10 rounded-full bg-amber-50 text-amber-600 hover:bg-amber-500 hover:text-white flex items-center justify-center transition shadow-sm" title="Site Oficial">
                                        <i class="fas fa-globe text-lg"></i>
                                    </a>
                                <% } %>

                                <% if (!empresa.whatsapp && !empresa.instagram && !empresa.facebook && !empresa.link_maps && !empresa.site) { %>
                                    <span class="text-xs text-gray-400 italic font-medium mt-2">Nenhum contato direto informado.</span>
                                <% } %>
                            </div>
                        </div>

                    <% } else { %>
                        <!-- ======================================================== -->
                        <!-- 🥇 CARTÃO PLANOS PAGOS (Premium e Patrocinado: C/ Imagem) -->
                        <!-- ======================================================== -->
                        <a href="/<%= empresa.slug %>" class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition duration-300 border border-gray-100 overflow-hidden flex flex-col relative">
                            
                            <% if (empresa.plano_id == 3) { %>
                                <div class="absolute top-3 right-3 z-10 bg-black/80 backdrop-blur-sm text-amber-400 text-[10px] font-black px-3 py-1 rounded-full uppercase border border-amber-500/30">
                                    <i class="fas fa-crown mr-1"></i> Patrocinado
                                </div>
                            <% } else if (empresa.plano_id == 2) { %>
                                <div class="absolute top-3 right-3 z-10 bg-white/90 backdrop-blur-sm text-amber-600 text-[10px] font-black px-3 py-1 rounded-full uppercase shadow-sm">
                                    <i class="fas fa-star mr-1"></i> Premium
                                </div>
                            <% } %>

                            <div class="h-48 overflow-hidden bg-gray-100 relative">
                                <% if(empresa.imagem) { %>
                                    <img src="<%= empresa.imagem %>" alt="<%= empresa.nome %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center text-gray-300"><i class="fas fa-camera text-4xl"></i></div>
                                <% } %>
                            </div>
                            
                            <div class="p-5 flex flex-col flex-grow">
                                <span class="text-[10px] font-bold text-amber-500 uppercase tracking-wider mb-1 block"><%= empresa.categoria_nome || 'Local' %></span>
                                <h3 class="text-lg font-bold text-gray-900 group-hover:text-amber-600 transition leading-tight mb-2"><%= empresa.nome %></h3>
                                
                                <div class="mt-auto pt-4 border-t border-gray-50 flex justify-between items-center text-sm font-bold text-slate-800">
                                    <span>Ver Detalhes</span>
                                    <i class="fas fa-chevron-right text-amber-500 group-hover:translate-x-1 transition"></i>
                                </div>
                            </div>
                        </a>
                    <% } %>

                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
                <i class="fas fa-search-minus text-5xl text-gray-300 mb-4"></i>
                <h3 class="text-xl font-bold text-gray-800 mb-2">Nenhum local encontrado</h3>
                <p class="text-gray-500 mb-6">Tente usar outros termos ou limpe os filtros para ver mais opções.</p>
                <a href="/explorar" class="inline-block bg-amber-500 text-white font-bold py-2 px-6 rounded-lg hover:bg-amber-600 transition">Ver Todos os Locais</a>
            </div>
        <% } %>
    </main>

    <footer class="bg-gray-900 text-white py-8 border-t border-gray-800 text-center">
        <p class="text-gray-500 text-sm">© <%= new Date().getFullYear() %> Portal São Thomé das Letras. Operado por Resultados Online.</p>
    </footer>

    <!-- ========================================== -->
    <!-- 🍪 POP-UP LGPD (AVISO DE COOKIES)          -->
    <!-- ========================================== -->
    <div id="lgpd-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-8 md:w-[400px] bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 z-[9999] transform translate-y-full opacity-0 transition-all duration-500 flex flex-col pointer-events-none">
        <div class="flex items-start gap-4">
            <div class="text-4xl">🍪</div>
            <div>
                <h4 class="font-black text-slate-900 text-lg mb-1">Privacidade e Cookies</h4>
                <p class="text-sm text-slate-500 leading-relaxed mb-4">
                    Utilizamos cookies para melhorar a sua experiência, personalizar anúncios e gerar estatísticas de acesso. Ao continuar a navegar, você concorda com a nossa política de privacidade.
                </p>
            </div>
        </div>
        <div class="flex gap-3 mt-auto">
            <button id="lgpd-recusar" class="flex-1 px-4 py-2.5 rounded-xl border border-slate-200 text-slate-600 font-bold text-sm hover:bg-slate-50 transition">
                Apenas Essenciais
            </button>
            <button id="lgpd-aceitar" class="flex-1 px-4 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm shadow-md shadow-amber-500/20 transition">
                Aceitar Tudo
            </button>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const banner = document.getElementById('lgpd-banner');
            const btnAceitar = document.getElementById('lgpd-aceitar');
            const btnRecusar = document.getElementById('lgpd-recusar');

            if (!localStorage.getItem('stl_lgpd_consent')) {
                setTimeout(() => {
                    banner.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
                }, 1000);
            }

            function fecharBanner(resposta) {
                localStorage.setItem('stl_lgpd_consent', resposta);
                if(resposta === 'aceitou' && typeof gtag === 'function') {
                    gtag('event', 'consentimento_lgpd', { 'status': 'aceito' });
                }
                banner.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
            }

            btnAceitar.addEventListener('click', () => fecharBanner('aceitou'));
            btnRecusar.addEventListener('click', () => fecharBanner('recusou'));
        });
    </script>
</body>
</html>
