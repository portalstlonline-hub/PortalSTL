<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastrar Nova Empresa - Portal STL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <header class="bg-slate-900 text-white py-4 px-6 shadow-md sticky top-0 z-50">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <div class="text-xl font-black tracking-tight text-slate-100">
                PORTAL<span class="text-amber-500">STL</span> <span class="text-slate-400 font-normal text-sm ml-2">| Novo Cadastro</span>
            </div>
            <a href="/admin" class="bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2 border border-slate-700">
                <i class="fas fa-arrow-left"></i> Voltar ao Painel
            </a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-10">
        
        <div class="mb-8 text-center md:text-left">
            <h1 class="text-3xl font-black text-slate-900">Cadastrar Empresa</h1>
            <p class="text-slate-500 mt-1">Adicione um novo negócio ou serviço ao diretório de São Thomé.</p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-10">
            <form action="/admin/nova" method="POST" enctype="multipart/form-data" class="space-y-6">
                
                <h3 class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b flex items-center gap-2">
                    <i class="fas fa-id-card text-amber-500"></i> Informações de Registro
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Nome da Empresa *</label>
                        <input type="text" name="nome" placeholder="Ex: Pousada do Sol" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition" required>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Categoria *</label>
                        <select name="categoria_id" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition" required>
                            <option value="">Selecione uma categoria...</option>
                            <% categorias.forEach(cat => { %>
                                <option value="<%= cat.id %>"><%= cat.nome %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wider">Definir Plano</label>
                        <select name="plano_id" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-amber-500 outline-none transition font-medium">
                            <option value="1">1. Start (Gratuito)</option>
                            <option value="2">2. Vitrine Premium</option>
                            <option value="3">3. Patrocinado (Destaque Home)</option>
                        </select>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wider">Status Inicial</label>
                        <select name="status" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-amber-500 outline-none transition font-bold">
                            <option value="ativo">🟢 Ativo (Publicar agora)</option>
                            <option value="inativo" selected>🔴 Inativo (Rascunho)</option>
                        </select>
                    </div>
                </div>

                <h3 class="text-lg font-bold text-slate-900 mt-8 mb-4 pb-2 border-b flex items-center gap-2">
                    <i class="fas fa-camera text-amber-500"></i> Fotos e Descrição
                </h3>

                <div class="mb-5">
                    <label class="block text-sm font-bold text-slate-700 mb-1">Descrição do Negócio</label>
                    <textarea name="descricao" rows="4" placeholder="Fale um pouco sobre a empresa, diferenciais, horários..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition resize-none"></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="bg-slate-50 p-5 rounded-xl border border-dashed border-slate-300">
                        <label class="block text-sm font-bold text-slate-700 mb-3">Foto de Capa Principal</label>
                        <input type="file" name="foto" accept="image/*" class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-slate-200 file:text-slate-700 hover:file:bg-slate-300 transition cursor-pointer">
                        <p class="text-[10px] text-slate-400 mt-2 italic">Imagem que aparecerá nas buscas.</p>
                    </div>

                    <div class="bg-amber-50 p-5 rounded-xl border border-dashed border-amber-300">
                        <label class="block text-sm font-bold text-amber-800 mb-3">Galeria de Fotos (Até 6)</label>
                        <input type="file" name="galeria" accept="image/*" multiple class="w-full text-sm text-amber-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-amber-500 file:text-white hover:file:bg-amber-600 transition cursor-pointer">
                        <p class="text-[10px] text-amber-600 mt-2 font-bold uppercase tracking-wider">
                            <i class="fas fa-check-circle"></i> Upgrade: Selecione até 6 imagens.
                        </p>
                    </div>
                </div>

                <h3 class="text-lg font-bold text-slate-900 mt-8 mb-4 pb-2 border-b flex items-center gap-2">
                    <i class="fas fa-phone-alt text-amber-500"></i> Contatos e Redes
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">WhatsApp (Só números)</label>
                        <input type="text" name="whatsapp" placeholder="35999999999" class="w-full px-4 py-3 rounded-xl border border-slate-300 outline-none focus:border-amber-500 transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Instagram (@)</label>
                        <input type="text" name="instagram" placeholder="@seuinsta" class="w-full px-4 py-3 rounded-xl border border-slate-300 outline-none focus:border-amber-500 transition">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Endereço</label>
                        <input type="text" name="endereco" placeholder="Ex: Rua da Lua, 50" class="w-full px-4 py-3 rounded-xl border border-slate-300 outline-none focus:border-amber-500 transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Link Google Maps</label>
                        <input type="url" name="link_maps" placeholder="https://goo.gl/maps/..." class="w-full px-4 py-3 rounded-xl border border-slate-300 outline-none focus:border-amber-500 transition">
                    </div>
                </div>

                <div class="mt-10 pt-8 border-t border-slate-100">
                    <button type="submit" class="w-full bg-slate-900 hover:bg-black text-white font-black py-5 rounded-2xl transition shadow-xl hover:scale-[1.01] flex justify-center items-center gap-3 text-lg">
                        <i class="fas fa-rocket"></i> CADASTRAR EMPRESA NO PORTAL
                    </button>
                </div>
            </form>
        </div>
    </main>

</body>
</html>
