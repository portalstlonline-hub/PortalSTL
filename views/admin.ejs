<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QG Resultados Online - Portal STL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Esconde a barra de rolagem mas permite o scroll nas abas no telemóvel */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-gray-100 font-sans text-gray-800">

    <!-- CABEÇALHO DO PAINEL -->
    <header class="bg-white border-b border-gray-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
            <div class="flex items-center">
                <a href="/admin" class="flex items-center">
                    <img src="/uploads/portallogomarca.png" alt="Portal STL" class="h-10 md:h-12 w-auto object-contain">
                </a>
                <span class="text-sm font-bold text-gray-400 ml-4 hidden md:inline border-l border-gray-200 pl-4 uppercase tracking-wider">Painel Admin</span>
            </div>
            <a href="/" target="_blank" class="bg-slate-900 hover:bg-black text-white px-5 py-2.5 rounded-lg transition duration-300 text-sm font-bold shadow-sm flex items-center">
                <i class="fas fa-external-link-alt mr-2 text-amber-500"></i> Ver Portal
            </a>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- ========================================== -->
        <!-- 🤖 AUTOMAÇÃO: VARREDURA DO GOOGLE          -->
        <!-- ========================================== -->
        <section class="bg-white rounded-xl shadow-md p-6 mb-8 border-l-4 border-blue-500">
            <h2 class="text-xl font-bold mb-4 flex items-center text-gray-800">
                <i class="fas fa-robot text-blue-500 mr-2"></i> Robô Caçador (Google Places)
            </h2>
            <form action="/admin/importar-google" method="POST" class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label class="block text-sm font-medium text-gray-700 mb-1">O que procurar em São Thomé? (Ex: Pousada)</label>
                    <input type="text" name="termo_busca" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 border p-2">
                </div>
                <div class="flex-1 w-full">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Salvar em qual Categoria?</label>
                    <select name="categoria_id" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 border p-2 bg-white">
                        <option value="">Selecione...</option>
                        <% categoriasLista.forEach(cat => { %>
                            <option value="<%= cat.id %>"><%= cat.nome %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full md:w-auto bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-md shadow transition duration-300 flex items-center justify-center h-10">
                    <i class="fas fa-search mr-2"></i> Iniciar Varredura
                </button>
            </form>
        </section>

        <!-- ========================================== -->
        <!-- 🗂️ GESTÃO UNIFICADA (EMPRESAS E CATEGORIAS) -->
        <!-- ========================================== -->
        <section class="bg-white rounded-xl shadow-md overflow-hidden mb-8">
            
            <!-- 🗂️ HEADER COM ABAS DINÂMICAS -->
            <div class="bg-gray-50 border-b border-gray-200 px-4 sm:px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="flex gap-6 w-full sm:w-auto overflow-x-auto no-scrollbar">
                    <!-- Aba: Empresas -->
                    <button onclick="switchTab('empresas')" id="btn-tab-empresas" class="py-4 border-b-2 border-emerald-500 text-emerald-600 font-bold flex items-center gap-2 whitespace-nowrap transition duration-300">
                        <i class="fas fa-store"></i> Empresas e Clientes
                    </button>
                    <!-- Aba: Categorias -->
                    <button onclick="switchTab('categorias')" id="btn-tab-categorias" class="py-4 border-b-2 border-transparent text-gray-500 hover:text-purple-600 font-bold flex items-center gap-2 whitespace-nowrap transition duration-300">
                        <i class="fas fa-tags"></i> Categorias e SEO
                    </button>
                </div>
                
                <!-- Botão Nova Empresa (Visível apenas na aba Empresas) -->
                <div id="action-empresas" class="w-full sm:w-auto pb-4 sm:pb-0 flex sm:block">
                    <a href="/admin/nova" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-2 px-4 rounded shadow transition duration-300 flex items-center justify-center whitespace-nowrap">
                        <i class="fas fa-plus mr-1"></i> Nova Empresa
                    </a>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- 🏢 CONTEÚDO 1: ABA DE EMPRESAS             -->
            <!-- ========================================== -->
            <div id="content-empresas" class="block">
                
                <!-- 🔍 Filtro de Busca em Tempo Real -->
                <div class="p-4 bg-white border-b border-gray-200 flex flex-col md:flex-row gap-4 items-center">
                    <div class="flex-1 w-full relative">
                        <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
                        <input type="text" id="pesquisaEmpresa" placeholder="Buscar cliente por nome..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500 outline-none transition">
                    </div>
                    <div class="w-full md:w-64">
                        <select id="filtroCategoria" class="w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500 outline-none transition bg-white">
                            <option value="">Todas as Categorias</option>
                            <% categoriasLista.forEach(cat => { %>
                                <option value="<%= cat.nome %>"><%= cat.nome %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                
                <!-- 📊 Tabela de Empresas (Corrigido o overflow e corte na direita) -->
                <div class="w-full overflow-x-auto">
                    <!-- Foi adicionado w-full min-w-max para a tabela nunca ser cortada -->
                    <table class="w-full min-w-max divide-y divide-gray-200">
                        <thead class="bg-gray-800 text-white">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Capa</th>
                                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Empresa</th>
                                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Categoria</th>
                                <th class="px-6 py-3 text-center text-xs font-medium uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-center text-xs font-medium text-yellow-300 uppercase tracking-wider"><i class="fas fa-eye mr-1"></i> Acessos</th>
                                <!-- Espaçamento extra à direita (pr-8) para a Lixeira não ficar colada na tela -->
                                <th class="px-6 py-3 pr-8 text-right text-xs font-medium uppercase tracking-wider">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200" id="tabelaEmpresas">
                            <% if(empresas && empresas.length > 0) { %>
                                <% empresas.forEach(empresa => { %>
                                <tr class="hover:bg-gray-50 transition duration-150 linha-empresa">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <% if (empresa.imagem) { %>
                                            <img src="<%= empresa.imagem %>" alt="Capa" class="h-10 w-10 rounded-md object-cover border border-gray-300">
                                        <% } else { %>
                                            <div class="h-10 w-10 rounded-md bg-gray-200 flex items-center justify-center text-gray-400 border border-gray-300">
                                                <i class="fas fa-image"></i>
                                            </div>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-bold text-gray-900 nome-empresa"><%= empresa.nome %></div>
                                        <div class="text-xs text-gray-500">Plano: <%= empresa.plano_id == 3 ? 'Patrocinado' : (empresa.plano_id == 2 ? 'Premium' : 'Básico') %></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 cat-empresa">
                                        <%= empresa.categoria_nome || 'Sem Categoria' %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        <% if (empresa.status === 'ativo') { %>
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Ativo</span>
                                        <% } else if (empresa.status === 'aprovacao') { %>
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-orange-100 text-orange-800 animate-pulse">Aprovação</span>
                                        <% } else { %>
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Inativo/Rascunho</span>
                                        <% } %>
                                    </td>
                                    
                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        <span class="bg-blue-50 text-blue-700 font-bold px-3 py-1 rounded-full text-sm border border-blue-200">
                                            <%= empresa.acessos || 0 %>
                                        </span>
                                    </td>

                                    <td class="px-6 py-4 pr-8 whitespace-nowrap text-right text-sm font-medium">
                                        <a href="/<%= empresa.slug %>" target="_blank" class="text-gray-500 hover:text-gray-900 mr-3" title="Ver no Site"><i class="fas fa-external-link-alt"></i></a>
                                        <a href="/admin/editar/<%= empresa.id %>" class="text-blue-600 hover:text-blue-900 mr-3" title="Editar"><i class="fas fa-edit"></i></a>
                                        <a href="/admin/excluir/<%= empresa.id %>" onclick="return confirm('Tem a certeza que deseja excluir esta empresa para sempre?')" class="text-red-600 hover:text-red-900" title="Excluir"><i class="fas fa-trash"></i></a>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr id="linhaVazia">
                                    <td colspan="6" class="px-6 py-10 text-center text-gray-500">Nenhuma empresa registada ainda. O robô está à espera das suas ordens!</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- 🏷️ CONTEÚDO 2: ABA DE CATEGORIAS           -->
            <!-- ========================================== -->
            <div id="content-categorias" class="hidden">
                <div class="p-6 border-b border-gray-200 bg-purple-50 flex flex-col md:flex-row justify-between items-center gap-4">
                    <h3 class="text-lg font-bold text-purple-900 flex items-center">
                        <i class="fas fa-plus-circle mr-2"></i> Criar Nova Categoria
                    </h3>
                    <form action="/admin/categorias" method="POST" class="flex w-full md:w-auto gap-4">
                        <input type="text" name="nome_categoria" placeholder="Ex: Pousadas" required class="flex-1 w-full md:w-64 border-gray-300 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 border p-2 outline-none transition">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-6 rounded shadow transition duration-300 whitespace-nowrap">
                            Adicionar
                        </button>
                    </form>
                </div>
                
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 bg-white">
                    <% categoriasLista.forEach(cat => { %>
                        <div class="border border-gray-200 rounded-lg p-5 shadow-sm hover:shadow-md transition duration-300 relative bg-gray-50">
                            <div class="absolute top-2 right-2">
                                <a href="/admin/categorias/excluir/<%= cat.id %>" onclick="return confirm('Isto não apagará as empresas, mas irá deixá-las sem categoria. Tem a certeza?')" class="text-red-400 hover:text-red-600 p-2" title="Excluir Categoria">
                                    <i class="fas fa-times-circle text-lg"></i>
                                </a>
                            </div>
                            <h4 class="font-bold text-lg text-gray-800 mb-3 border-b pb-2 pr-6"><%= cat.nome %></h4>
                            <form action="/admin/categorias/atualizar/<%= cat.id %>" method="POST">
                                <input type="hidden" name="nome" value="<%= cat.nome %>">
                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1"><i class="fas fa-search text-gray-400 mr-1"></i> Palavras-Chave Ocultas (SEO)</label>
                                <textarea name="palavras_chave" rows="2" placeholder="Ex: dormir, descansar, cama, hotel" class="w-full text-sm border-gray-300 rounded p-2 border focus:ring-purple-500 focus:border-purple-500 mb-3 outline-none transition"><%= cat.palavras_chave || '' %></textarea>
                                <button type="submit" class="w-full bg-purple-100 hover:bg-purple-200 text-purple-800 text-sm font-bold py-2 px-2 rounded transition duration-300">
                                    <i class="fas fa-save mr-1"></i> Salvar SEO
                                </button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </div>

        </section>

    </main>

    <!-- 🛠️ SCRIPTS DO PAINEL ADMIN (Filtro e Abas) -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            // --- LÓGICA DO FILTRO EM TEMPO REAL ---
            const inputPesquisa = document.getElementById('pesquisaEmpresa');
            const selectCategoria = document.getElementById('filtroCategoria');
            const linhasEmpresa = document.querySelectorAll('.linha-empresa');

            function filtrarTabela() {
                const termoTexto = inputPesquisa.value.toLowerCase();
                const termoCategoria = selectCategoria.value.toLowerCase();

                linhasEmpresa.forEach(linha => {
                    const nome = linha.querySelector('.nome-empresa').textContent.toLowerCase();
                    const categoria = linha.querySelector('.cat-empresa').textContent.toLowerCase().trim();

                    const matchTexto = nome.includes(termoTexto);
                    const matchCategoria = termoCategoria === "" || categoria === termoCategoria;

                    if (matchTexto && matchCategoria) {
                        linha.style.display = '';
                    } else {
                        linha.style.display = 'none';
                    }
                });
            }

            if(inputPesquisa && selectCategoria) {
                inputPesquisa.addEventListener('keyup', filtrarTabela);
                selectCategoria.addEventListener('change', filtrarTabela);
            }
        });

        // --- LÓGICA DE TROCA DE ABAS (TABS) ---
        function switchTab(tab) {
            const contentEmpresas = document.getElementById('content-empresas');
            const contentCategorias = document.getElementById('content-categorias');
            const btnEmpresas = document.getElementById('btn-tab-empresas');
            const btnCategorias = document.getElementById('btn-tab-categorias');
            const actionEmpresas = document.getElementById('action-empresas');

            if (tab === 'empresas') {
                // Mostrar Empresas
                contentEmpresas.classList.remove('hidden');
                contentCategorias.classList.add('hidden');
                actionEmpresas.classList.remove('hidden');
                actionEmpresas.classList.add('sm:block'); // Mantém visível em desktop
                
                // Estilo Ativo: Empresas
                btnEmpresas.className = "py-4 border-b-2 border-emerald-500 text-emerald-600 font-bold flex items-center gap-2 whitespace-nowrap transition duration-300";
                btnCategorias.className = "py-4 border-b-2 border-transparent text-gray-500 hover:text-purple-600 font-bold flex items-center gap-2 whitespace-nowrap transition duration-300";
            } else {
                // Mostrar Categorias
                contentEmpresas.classList.add('hidden');
                contentCategorias.classList.remove('hidden');
                actionEmpresas.classList.add('hidden');
                actionEmpresas.classList.remove('sm:block');
                
                // Estilo Ativo: Categorias
                btnCategorias.className = "py-4 border-b-2 border-purple-500 text-purple-600 font-bold flex items-center gap-2 whitespace-nowrap transition duration-300";
                btnEmpresas.className = "py-4 border-b-2 border-transparent text-gray-500 hover:text-emerald-600 font-bold flex items-center gap-2 whitespace-nowrap transition duration-300";
            }
        }
    </script>
</body>
</html>
