<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QG Resultados Online - Portal STL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Biblioteca para gerar PDF Mágico -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <style>
        /* Ajuste fino para não quebrar a tela */
        body { overflow-x: hidden; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-gray-100 font-sans text-gray-800">

    <!-- 📊 CÁLCULOS DOS NÚMEROS DO PORTAL (Upgrade Iago: Separação de Premium e Patrocinado + Ranking) -->
    <% 
        let totalEmpresas = empresas ? empresas.length : 0;
        let totalOnline = empresas ? empresas.filter(e => e.status === 'ativo').length : 0;
        let totalAprovacao = empresas ? empresas.filter(e => e.status === 'aprovacao').length : 0;
        let totalVitrine = empresas ? empresas.filter(e => e.plano_id == 2 && e.status === 'ativo').length : 0;
        let totalPatrocinado = empresas ? empresas.filter(e => e.plano_id == 3 && e.status === 'ativo').length : 0;
        let top10Empresas = empresas ? [...empresas].sort((a, b) => (b.acessos || 0) - (a.acessos || 0)).slice(0, 10) : [];
    %>

    <!-- CABEÇALHO DO PAINEL -->
    <header class="bg-white border-b border-gray-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
            <div class="flex items-center">
                <a href="/admin" class="flex items-center">
                    <img src="/uploads/portallogomarca.png" alt="Portal STL" class="h-10 md:h-12 w-auto object-contain">
                </a>
                <span class="text-sm font-bold text-gray-400 ml-4 hidden md:inline border-l border-gray-200 pl-4 uppercase tracking-wider">Painel Admin</span>
            </div>
            <a href="/" target="_blank" class="bg-slate-900 hover:bg-black text-white px-5 py-2.5 rounded-lg transition duration-300 text-sm font-bold shadow-sm flex items-center whitespace-nowrap">
                <i class="fas fa-external-link-alt mr-2 text-amber-500"></i> Ver Portal
            </a>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
        
        <!-- ========================================== -->
        <!-- 📈 DASHBOARD DE INDICADORES (NÚMEROS)      -->
        <!-- ========================================== -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
            <!-- Total -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center gap-3 md:gap-4">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center text-lg md:text-xl flex-shrink-0">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <div>
                    <p class="text-[10px] md:text-xs text-gray-500 font-bold uppercase tracking-wider">Total Portal</p>
                    <h3 class="text-xl md:text-2xl font-black text-gray-800"><%= totalEmpresas %></h3>
                </div>
            </div>
            <!-- Online -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center gap-3 md:gap-4">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center text-lg md:text-xl flex-shrink-0">
                    <i class="fas fa-globe"></i>
                </div>
                <div>
                    <p class="text-[10px] md:text-xs text-gray-500 font-bold uppercase tracking-wider">Online</p>
                    <h3 class="text-xl md:text-2xl font-black text-gray-800"><%= totalOnline %></h3>
                </div>
            </div>
            <!-- Em Aprovação -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center gap-3 md:gap-4">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-orange-50 text-orange-500 flex items-center justify-center text-lg md:text-xl flex-shrink-0">
                    <i class="fas fa-user-clock"></i>
                </div>
                <div>
                    <p class="text-[10px] md:text-xs text-gray-500 font-bold uppercase tracking-wider">Aprovação</p>
                    <h3 class="text-xl md:text-2xl font-black text-gray-800"><%= totalAprovacao %></h3>
                </div>
            </div>
            <!-- Vitrine Premium -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center gap-3 md:gap-4">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center text-lg md:text-xl flex-shrink-0">
                    <i class="fas fa-star"></i>
                </div>
                <div>
                    <p class="text-[10px] md:text-xs text-gray-500 font-bold uppercase tracking-wider">Premium</p>
                    <h3 class="text-xl md:text-2xl font-black text-gray-800"><%= totalVitrine %></h3>
                </div>
            </div>
            <!-- Patrocinados -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex items-center gap-3 md:gap-4">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-900 text-amber-400 flex items-center justify-center text-lg md:text-xl flex-shrink-0">
                    <i class="fas fa-crown"></i>
                </div>
                <div>
                    <p class="text-[10px] md:text-xs text-gray-500 font-bold uppercase tracking-wider">Patrocinados</p>
                    <h3 class="text-xl md:text-2xl font-black text-gray-800"><%= totalPatrocinado %></h3>
                </div>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- 🤖 AUTOMAÇÃO: VARREDURA DO GOOGLE          -->
        <!-- ========================================== -->
        <section class="bg-white rounded-xl shadow-md p-6 mb-8 border-l-4 border-blue-500">
            <h2 class="text-lg font-bold mb-4 flex items-center text-gray-800">
                <i class="fas fa-robot text-blue-500 mr-2"></i> Robô Caçador (Google Places)
            </h2>
            <form action="/admin/importar-google" method="POST" class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Buscar em São Thomé? (Ex: Pizzaria)</label>
                    <input type="text" name="termo_busca" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 border p-2 text-sm">
                </div>
                <div class="flex-1 w-full">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Categoria de destino</label>
                    <select name="categoria_id" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 border p-2 bg-white text-sm">
                        <option value="">Selecione...</option>
                        <% categoriasLista.forEach(cat => { %>
                            <option value="<%= cat.id %>"><%= cat.nome %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full md:w-auto bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-md shadow transition duration-300 flex items-center justify-center h-10 whitespace-nowrap text-sm">
                    <i class="fas fa-search mr-2"></i> Varredura
                </button>
            </form>
        </section>

        <!-- ========================================== -->
        <!-- 🗂️ GESTÃO UNIFICADA COM 3 ABAS            -->
        <!-- ========================================== -->
        <section class="bg-white rounded-xl shadow-md overflow-hidden mb-8 w-full">
            
            <!-- 🗂️ HEADER DAS ABAS -->
            <div class="bg-gray-50 border-b border-gray-200 px-4 flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="flex gap-4 w-full sm:w-auto overflow-x-auto no-scrollbar">
                    <button onclick="switchTab('empresas')" id="btn-tab-empresas" class="py-4 border-b-2 border-emerald-500 text-emerald-600 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm">
                        <i class="fas fa-store"></i> Clientes
                    </button>
                    <button onclick="switchTab('categorias')" id="btn-tab-categorias" class="py-4 border-b-2 border-transparent text-gray-500 hover:text-purple-600 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm">
                        <i class="fas fa-tags"></i> Categorias
                    </button>
                    <button onclick="switchTab('relatorios')" id="btn-tab-relatorios" class="py-4 border-b-2 border-transparent text-gray-500 hover:text-amber-600 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm">
                        <i class="fas fa-chart-pie"></i> Relatórios e BI
                    </button>
                </div>
                
                <div id="action-empresas" class="w-full sm:w-auto pb-4 sm:pb-0">
                    <a href="/admin/nova" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-2 px-4 rounded shadow transition duration-300 flex items-center justify-center whitespace-nowrap text-sm">
                        <i class="fas fa-plus mr-1"></i> Nova Empresa
                    </a>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- 🏢 ABA 1: EMPRESAS (Tabela 100% Encaixada) -->
            <!-- ========================================== -->
            <div id="content-empresas" class="block w-full">
                <div class="p-4 bg-white border-b border-gray-200 flex flex-col md:flex-row gap-4 items-center">
                    <div class="flex-1 w-full relative">
                        <i class="fas fa-search absolute left-3 top-2.5 text-gray-400 text-sm"></i>
                        <input type="text" id="pesquisaEmpresa" placeholder="Buscar cliente..." class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500 outline-none">
                    </div>
                    <div class="w-full md:w-64">
                        <select id="filtroCategoria" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-white">
                            <option value="">Todas Categorias</option>
                            <% categoriasLista.forEach(cat => { %>
                                <option value="<%= cat.nome %>"><%= cat.nome %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                
                <!-- Tabela Enxuta (Sem imagem de Capa, sem horizontal scroll forçado) -->
                <div class="w-full">
                    <table class="w-full divide-y divide-gray-200 table-fixed">
                        <thead class="bg-gray-800 text-white">
                            <tr>
                                <th class="w-1/3 px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Empresa</th>
                                <th class="w-1/4 px-4 py-3 text-left text-xs font-medium uppercase tracking-wider hidden sm:table-cell">Categoria</th>
                                <th class="w-1/6 px-4 py-3 text-center text-xs font-medium uppercase tracking-wider hidden md:table-cell">Status</th>
                                <th class="w-1/6 px-4 py-3 text-center text-xs font-medium text-yellow-300 uppercase tracking-wider"><i class="fas fa-eye"></i> Visitas</th>
                                <th class="w-1/6 px-4 py-3 text-right text-xs font-medium uppercase tracking-wider">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200" id="tabelaEmpresas">
                            <% if(empresas && empresas.length > 0) { %>
                                <% empresas.forEach(empresa => { %>
                                <tr class="hover:bg-gray-50 transition duration-150 linha-empresa">
                                    <td class="px-4 py-3 overflow-hidden">
                                        <div class="text-sm font-bold text-gray-900 truncate nome-empresa"><%= empresa.nome %></div>
                                        <div class="text-xs text-gray-500 truncate">Plano: <%= empresa.plano_id == 3 ? 'Patrocinado' : (empresa.plano_id == 2 ? 'Premium' : 'Básico') %></div>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-500 cat-empresa truncate hidden sm:table-cell">
                                        <%= empresa.categoria_nome || 'S/ Categoria' %>
                                    </td>
                                    <td class="px-4 py-3 text-center hidden md:table-cell">
                                        <% if (empresa.status === 'ativo') { %>
                                            <span class="px-2 py-1 text-[10px] font-bold rounded-md bg-green-100 text-green-800">Ativo</span>
                                        <% } else if (empresa.status === 'aprovacao') { %>
                                            <span class="px-2 py-1 text-[10px] font-bold rounded-md bg-orange-100 text-orange-800">Pendente</span>
                                        <% } else { %>
                                            <span class="px-2 py-1 text-[10px] font-bold rounded-md bg-gray-100 text-gray-600">Inativo</span>
                                        <% } %>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="text-blue-600 font-bold text-sm"><%= empresa.acessos || 0 %></span>
                                    </td>
                                    <td class="px-4 py-3 text-right text-sm font-medium whitespace-nowrap">
                                        <a href="/<%= empresa.slug %>" target="_blank" class="text-gray-400 hover:text-gray-900 mr-2" title="Ver Site"><i class="fas fa-external-link-alt"></i></a>
                                        <a href="/admin/editar/<%= empresa.id %>" class="text-blue-500 hover:text-blue-800 mr-2" title="Editar"><i class="fas fa-edit"></i></a>
                                        <a href="/admin/excluir/<%= empresa.id %>" onclick="return confirm('Apagar definitivamente?')" class="text-red-500 hover:text-red-800" title="Excluir"><i class="fas fa-trash"></i></a>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr id="linhaVazia">
                                    <td colspan="5" class="px-6 py-10 text-center text-gray-500">Nenhuma empresa registada.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- 🏷️ ABA 2: CATEGORIAS E SEO                 -->
            <!-- ========================================== -->
            <div id="content-categorias" class="hidden w-full">
                <div class="p-6 border-b border-gray-200 bg-purple-50 flex flex-col md:flex-row justify-between items-center gap-4">
                    <h3 class="text-lg font-bold text-purple-900 flex items-center">
                        <i class="fas fa-plus-circle mr-2"></i> Criar Categoria
                    </h3>
                    <form action="/admin/categorias" method="POST" class="flex w-full md:w-auto gap-3">
                        <input type="text" name="nome_categoria" placeholder="Ex: Pousadas" required class="flex-1 w-full md:w-64 border-gray-300 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 border p-2 text-sm outline-none">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded shadow transition whitespace-nowrap text-sm">
                            Adicionar
                        </button>
                    </form>
                </div>
                
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 bg-white">
                    <% categoriasLista.forEach(cat => { %>
                        <div class="border border-gray-200 rounded-lg p-5 bg-gray-50 relative">
                            <div class="absolute top-2 right-2">
                                <a href="/admin/categorias/excluir/<%= cat.id %>" onclick="return confirm('Tem a certeza?')" class="text-red-400 hover:text-red-600 p-2">
                                    <i class="fas fa-times-circle"></i>
                                </a>
                            </div>
                            <h4 class="font-bold text-lg text-gray-800 mb-3 border-b pb-2 pr-6"><%= cat.nome %></h4>
                            <form action="/admin/categorias/atualizar/<%= cat.id %>" method="POST">
                                <input type="hidden" name="nome" value="<%= cat.nome %>">
                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Palavras-Chave (SEO)</label>
                                <textarea name="palavras_chave" rows="2" placeholder="Ex: dormir, hotel..." class="w-full text-sm border-gray-300 rounded p-2 border focus:ring-purple-500 focus:border-purple-500 mb-3 outline-none"><%= cat.palavras_chave || '' %></textarea>
                                <button type="submit" class="w-full bg-purple-100 hover:bg-purple-200 text-purple-800 text-sm font-bold py-2 rounded transition">
                                    <i class="fas fa-save mr-1"></i> Salvar SEO
                                </button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- 📊 ABA 3: RELATÓRIOS E ESTATÍSTICAS (BI)   -->
            <!-- ========================================== -->
            <div id="content-relatorios" class="hidden w-full bg-white">
                
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 p-6 border-t border-gray-100">
                    
                    <!-- LADO ESQUERDO: CONTROLES DE BUSCA E RANKING -->
                    <div class="lg:col-span-1 space-y-6">
                        
                        <!-- Bloco: Pesquisa de Empresa -->
                        <div class="bg-gray-50 p-5 rounded-xl border border-gray-200">
                            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Procurar Cliente</label>
                            <div class="relative w-full">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-search text-gray-400"></i>
                                </div>
                                <input type="text" id="buscaRelatorio" class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg shadow-sm focus:ring-amber-500 focus:border-amber-500 text-sm outline-none transition" placeholder="Digite o nome da empresa..." autocomplete="off">
                                
                                <!-- Dropdown Customizado (Lista de Resultados) -->
                                <div id="listaRelatorio" class="absolute z-20 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-xl max-h-60 overflow-y-auto hidden">
                                    <!-- Preenchido via JavaScript -->
                                </div>
                            </div>
                        </div>

                        <!-- Bloco: Ranking Top 10 -->
                        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm">
                            <h3 class="text-sm font-bold text-gray-800 uppercase tracking-wider mb-4 flex items-center gap-2">
                                <i class="fas fa-trophy text-amber-500 text-lg"></i> Top 10 Acessos
                            </h3>
                            
                            <div class="space-y-2.5">
                                <% if(top10Empresas.length > 0) { %>
                                    <% top10Empresas.forEach((emp, index) => { %>
                                        <div class="flex items-center justify-between p-2.5 rounded-lg border cursor-pointer transition transform hover:scale-[1.02] <%= index === 0 ? 'bg-amber-50 border-amber-200' : (index === 1 ? 'bg-slate-100 border-slate-300' : (index === 2 ? 'bg-orange-50 border-orange-200' : 'bg-white border-gray-100 hover:bg-gray-50 hover:border-gray-300')) %>" onclick="selecionarEmpresaRelatorio(<%= emp.id %>)">
                                            <div class="flex items-center gap-3 overflow-hidden">
                                                <div class="w-6 text-center font-black text-lg <%= index === 0 ? 'text-amber-500' : (index === 1 ? 'text-slate-400' : (index === 2 ? 'text-orange-500' : 'text-gray-300 text-base')) %>">
                                                    <%= index + 1 %>º
                                                </div>
                                                <div class="text-sm font-bold <%= index < 3 ? 'text-gray-900' : 'text-gray-700' %> truncate" title="<%= emp.nome %>"><%= emp.nome %></div>
                                            </div>
                                            <div class="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded-md ml-2 flex-shrink-0 border border-blue-100">
                                                <%= emp.acessos || 0 %> <i class="fas fa-eye text-[10px] ml-0.5"></i>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="text-sm text-gray-500 text-center py-4">Nenhum dado de acesso ainda.</p>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- LADO DIREITO: O RELATÓRIO PDF -->
                    <div class="lg:col-span-2 flex flex-col h-full">
                        <div class="p-4 bg-gray-50 border border-gray-200 rounded-t-xl flex flex-col sm:flex-row justify-between items-center gap-3">
                            <h3 class="font-bold text-gray-700 flex items-center gap-2">
                                <i class="fas fa-file-invoice text-slate-400"></i> Relatório do Cliente
                            </h3>
                            <button onclick="gerarPDF()" id="btnDownloadPDF" class="w-full sm:w-auto bg-slate-900 hover:bg-black text-white font-bold py-2.5 px-5 rounded-md shadow transition flex items-center justify-center gap-2 opacity-50 cursor-not-allowed pointer-events-none text-xs uppercase tracking-wider">
                                <i class="fas fa-file-pdf text-red-400 text-base"></i> Exportar para PDF
                            </button>
                        </div>
                        
                        <!-- Área de Visualização do Relatório -->
                        <div class="p-6 bg-gray-200 flex-grow flex justify-center items-start min-h-[500px] border border-t-0 border-gray-200 rounded-b-xl relative overflow-hidden">
                            
                            <!-- Placeholder (Aparece enquanto não clica em ninguém) -->
                            <div id="placeholderRelatorio" class="absolute inset-0 flex flex-col items-center justify-center text-gray-400 bg-gray-100/80 z-10">
                                <i class="fas fa-search-chart text-6xl mb-4 opacity-50 text-amber-500"></i>
                                <p class="font-medium text-sm text-center">Pesquise uma empresa ou clique no ranking<br>para gerar o documento de BI.</p>
                            </div>

                            <!-- O RELATÓRIO VISUAL (Que será impresso no PDF) -->
                            <div id="areaRelatorio" class="w-full relative z-0">
                                <div id="folhaPDF" class="bg-white w-full max-w-3xl rounded-xl shadow-lg p-10 relative overflow-hidden mx-auto">
                                    
                                    <!-- Marca d'água -->
                                    <i class="fas fa-chart-line absolute -bottom-10 -right-10 text-[200px] text-gray-50 opacity-50 rotate-12 pointer-events-none"></i>

                                    <!-- Cabeçalho do PDF -->
                                    <div class="flex justify-between items-center border-b-2 border-gray-100 pb-6 mb-8 relative z-10">
                                        <div>
                                            <h1 class="text-3xl font-black text-slate-900">Relatório de Impacto</h1>
                                            <p class="text-sm text-gray-500 font-bold uppercase tracking-widest mt-1">Portal STL - Resultados Online</p>
                                        </div>
                                        <img src="/uploads/portallogomarca.png" class="h-10 opacity-80" alt="Logo">
                                    </div>

                                    <!-- Dados do Cliente -->
                                    <div class="mb-10 relative z-10">
                                        <h2 id="rep-nome" class="text-2xl font-bold text-slate-800">Nome do Cliente</h2>
                                        <p class="text-gray-500 text-sm mt-1 flex items-center gap-2">
                                            <span id="rep-plano" class="bg-amber-100 text-amber-800 px-2 py-0.5 rounded text-xs font-bold uppercase tracking-wider">Plano</span>
                                            <span id="rep-cat" class="text-gray-400"><i class="fas fa-tag"></i> Categoria</span>
                                        </p>
                                    </div>

                                    <!-- Grid de Métricas Principais -->
                                    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-10 relative z-10">
                                        
                                        <!-- Visitas na Página -->
                                        <div class="bg-blue-50 border border-blue-100 p-5 rounded-xl text-center">
                                            <i class="fas fa-eye text-blue-500 text-3xl mb-2"></i>
                                            <h3 id="rep-acessos" class="text-4xl font-black text-slate-800">0</h3>
                                            <p class="text-xs text-gray-500 font-bold uppercase mt-1">Acessos à Vitrine</p>
                                        </div>

                                        <!-- Cliques no WhatsApp -->
                                        <div class="bg-green-50 border border-green-100 p-5 rounded-xl text-center">
                                            <i class="fab fa-whatsapp text-green-500 text-3xl mb-2"></i>
                                            <h3 id="rep-wpp" class="text-4xl font-black text-slate-800">0</h3>
                                            <p class="text-xs text-gray-500 font-bold uppercase mt-1">Cliques no WhatsApp</p>
                                        </div>

                                        <!-- Cliques no Mapa -->
                                        <div class="bg-slate-50 border border-slate-200 p-5 rounded-xl text-center">
                                            <i class="fas fa-map-marked-alt text-slate-500 text-3xl mb-2"></i>
                                            <h3 id="rep-mapa" class="text-4xl font-black text-slate-800">0</h3>
                                            <p class="text-xs text-gray-500 font-bold uppercase mt-1">Rotas no Mapa</p>
                                        </div>

                                        <!-- Cliques nas Redes Sociais -->
                                        <div class="bg-pink-50 border border-pink-100 p-5 rounded-xl text-center">
                                            <i class="fab fa-instagram text-pink-500 text-3xl mb-2"></i>
                                            <h3 id="rep-social" class="text-4xl font-black text-slate-800">0</h3>
                                            <p class="text-xs text-gray-500 font-bold uppercase mt-1">Acessos Sociais</p>
                                        </div>

                                        <!-- Compartilhamentos -->
                                        <div class="bg-purple-50 border border-purple-100 p-5 rounded-xl text-center md:col-span-2">
                                            <i class="fas fa-share-nodes text-purple-500 text-3xl mb-2"></i>
                                            <h3 id="rep-share" class="text-4xl font-black text-slate-800">0</h3>
                                            <p class="text-xs text-gray-500 font-bold uppercase mt-1">Compartilhamentos e Boca a Boca</p>
                                        </div>

                                    </div>

                                    <!-- Rodapé do PDF -->
                                    <div class="border-t-2 border-gray-100 pt-6 mt-8 text-center relative z-10">
                                        <p class="text-xs text-gray-400 font-medium">Relatório gerado automaticamente pelo sistema de inteligência de dados da agência Resultados Online.</p>
                                        <p class="text-xs text-gray-400 font-medium mt-1">Data de Emissão: <span id="data-hoje"></span></p>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </section>

    </main>

    <!-- Transferência dos dados do Node.js para o Javascript do Navegador -->
    <script>
        const bdEmpresas = <%- JSON.stringify(empresas || []) %>;
    </script>

    <!-- 🛠️ SCRIPTS GERAIS DO PAINEL -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            // --- LÓGICA DO FILTRO DA TABELA PRINCIPAL ---
            const inputPesquisa = document.getElementById('pesquisaEmpresa');
            const selectCategoria = document.getElementById('filtroCategoria');
            const linhasEmpresa = document.querySelectorAll('.linha-empresa');

            function filtrarTabela() {
                const termoTexto = inputPesquisa.value.toLowerCase();
                const termoCategoria = selectCategoria.value.toLowerCase();

                linhasEmpresa.forEach(linha => {
                    const nome = linha.querySelector('.nome-empresa').textContent.toLowerCase();
                    const categoria = linha.querySelector('.cat-empresa').textContent.toLowerCase().trim();

                    const matchTexto = nome.includes(termoTexto);
                    const matchCategoria = termoCategoria === "" || categoria === termoCategoria;

                    if (matchTexto && matchCategoria) {
                        linha.style.display = '';
                    } else {
                        linha.style.display = 'none';
                    }
                });
            }

            if(inputPesquisa && selectCategoria) {
                inputPesquisa.addEventListener('keyup', filtrarTabela);
                selectCategoria.addEventListener('change', filtrarTabela);
            }

            // --- LÓGICA DO BUSCADOR DE RELATÓRIO (CUSTOM DROPDOWN) ---
            const inputBuscaRelatorio = document.getElementById('buscaRelatorio');
            const listaRelatorio = document.getElementById('listaRelatorio');

            if (inputBuscaRelatorio && listaRelatorio) {
                inputBuscaRelatorio.addEventListener('input', function() {
                    const termo = this.value.toLowerCase().trim();
                    listaRelatorio.innerHTML = ''; // Limpa a lista

                    if (termo.length === 0) {
                        listaRelatorio.classList.add('hidden');
                        return;
                    }

                    // Filtra as empresas pelo termo
                    const filtrados = bdEmpresas.filter(emp => emp.nome.toLowerCase().includes(termo));

                    if (filtrados.length === 0) {
                        listaRelatorio.innerHTML = '<div class="p-4 text-sm text-gray-500 text-center font-medium">Nenhuma empresa encontrada com esse nome.</div>';
                    } else {
                        filtrados.forEach(emp => {
                            const div = document.createElement('div');
                            div.className = 'p-3 hover:bg-gray-50 cursor-pointer border-b border-gray-100 flex justify-between items-center transition';
                            div.innerHTML = `
                                <div>
                                    <div class="font-bold text-sm text-gray-800 truncate max-w-[200px]">${emp.nome}</div>
                                    <div class="text-[10px] text-gray-500 uppercase font-bold mt-0.5">${emp.categoria_nome || 'Sem categoria'}</div>
                                </div>
                                <div class="text-[10px] uppercase bg-amber-100 text-amber-800 px-2 py-1 rounded font-bold ml-2">
                                    ${emp.plano_id == 3 ? '<i class="fas fa-crown"></i> Patroc.' : (emp.plano_id == 2 ? '<i class="fas fa-star"></i> Premium' : 'Start')}
                                </div>
                            `;
                            
                            // Ação ao clicar no item da lista
                            div.onclick = () => {
                                window.selecionarEmpresaRelatorio(emp.id);
                                inputBuscaRelatorio.value = emp.nome; // Preenche o campo com o nome escolhido
                                listaRelatorio.classList.add('hidden'); // Esconde a lista
                            };
                            
                            listaRelatorio.appendChild(div);
                        });
                    }
                    listaRelatorio.classList.remove('hidden');
                });

                // Fechar o menu dropdown se clicar fora dele
                document.addEventListener('click', (e) => {
                    if (!inputBuscaRelatorio.contains(e.target) && !listaRelatorio.contains(e.target)) {
                        listaRelatorio.classList.add('hidden');
                    }
                });
            }
        });

        // --- FUNÇÃO GLOBAL DO BI: PREENCHER E EXIBIR O RELATÓRIO ---
        window.selecionarEmpresaRelatorio = function(idSelecionado) {
            const emp = bdEmpresas.find(e => e.id === idSelecionado);
            if(!emp) return;

            // Transição visual: Some com o placeholder, exibe a folha
            document.getElementById('placeholderRelatorio').classList.add('hidden');
            document.getElementById('areaRelatorio').classList.remove('hidden');

            // Preenche dados do PDF
            document.getElementById('rep-nome').innerText = emp.nome;
            document.getElementById('rep-cat').innerText = emp.categoria_nome || 'Local';
            document.getElementById('rep-plano').innerText = emp.plano_id == 3 ? 'Patrocinado VIP' : (emp.plano_id == 2 ? 'Vitrine Premium' : 'Plano Grátis');
            
            // 📊 O Dado Real
            const acessos = emp.acessos || 0;
            document.getElementById('rep-acessos').innerText = acessos;

            // ⚠️ SIMULAÇÃO LÓGICA DO FUNIL (Até termos a Rota Secreta)
            document.getElementById('rep-wpp').innerText = Math.floor(acessos * 0.15); // 15%
            document.getElementById('rep-mapa').innerText = Math.floor(acessos * 0.25); // 25%
            document.getElementById('rep-social').innerText = Math.floor(acessos * 0.10); // 10%
            document.getElementById('rep-share').innerText = Math.floor(acessos * 0.05); // 5%

            document.getElementById('data-hoje').innerText = new Date().toLocaleDateString('pt-BR');

            // Libera o botão de Download
            document.getElementById('btnDownloadPDF').classList.remove('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
        };

        // --- FUNÇÃO DE GERAR PDF MAGICO ---
        function gerarPDF() {
            const folha = document.getElementById('folhaPDF');
            const nomeCliente = document.getElementById('rep-nome').innerText;
            
            const opcoes = {
                margin:       0,
                filename:     `BI-PortalSTL-${nomeCliente.replace(/ /g, '-')}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            // Dispara o download
            html2pdf().set(opcoes).from(folha).save();
        }

        // --- LÓGICA DE TROCA DE ABAS ---
        function switchTab(tab) {
            const contentEmpresas = document.getElementById('content-empresas');
            const contentCategorias = document.getElementById('content-categorias');
            const contentRelatorios = document.getElementById('content-relatorios');
            
            const btnEmpresas = document.getElementById('btn-tab-empresas');
            const btnCategorias = document.getElementById('btn-tab-categorias');
            const btnRelatorios = document.getElementById('btn-tab-relatorios');
            
            const actionEmpresas = document.getElementById('action-empresas');

            // Esconde Tudo Primeiro
            contentEmpresas.classList.add('hidden');
            contentCategorias.classList.add('hidden');
            contentRelatorios.classList.add('hidden');
            actionEmpresas.classList.add('hidden');
            
            // Reseta Estilos dos Botões
            const estiloInativo = "py-4 border-b-2 border-transparent text-gray-500 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm";
            btnEmpresas.className = estiloInativo + " hover:text-emerald-600";
            btnCategorias.className = estiloInativo + " hover:text-purple-600";
            btnRelatorios.className = estiloInativo + " hover:text-amber-600";

            if (tab === 'empresas') {
                contentEmpresas.classList.remove('hidden');
                actionEmpresas.classList.remove('hidden');
                actionEmpresas.classList.add('sm:block');
                btnEmpresas.className = "py-4 border-b-2 border-emerald-500 text-emerald-600 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm";
            } 
            else if (tab === 'categorias') {
                contentCategorias.classList.remove('hidden');
                actionEmpresas.classList.remove('sm:block');
                btnCategorias.className = "py-4 border-b-2 border-purple-500 text-purple-600 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm";
            }
            else if (tab === 'relatorios') {
                contentRelatorios.classList.remove('hidden');
                actionEmpresas.classList.remove('sm:block');
                btnRelatorios.className = "py-4 border-b-2 border-amber-500 text-amber-600 font-bold flex items-center gap-2 whitespace-nowrap transition text-sm";
            }
        }
    </script>
</body>
</html>
