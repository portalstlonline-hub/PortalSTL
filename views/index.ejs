<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Portal STL - Guia comercial e Turístico de São Thomé das Letras</title>
    <meta name="description" content="Um guia comercial e turístico completo! Encontre empresas, serviços, hospedagens, restaurantes e eventos na cidade mais mística do Brasil.">
    
    <!-- 🚨 OPEN GRAPH (A Mágica para o WhatsApp e Redes Sociais) 🚨 -->
    <meta property="og:title" content="Portal STL - São Thomé das Letras">
    <meta property="og:description" content="Um guia comercial e turístico completo! Encontre empresas, serviços, hospedagens, restaurantes e eventos na cidade mais mística do Brasil.">
    <meta property="og:url" content="https://portalsaothomedasletras.com.br/">
    <meta property="og:type" content="website">
    
    <!-- Imagem Exclusiva para Compartilhamento (1200x630) -->
    <meta property="og:image" content="https://portalsaothomedasletras.com.br/uploads/capa-compartilhamento.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/png">

    <!-- 🚨 O SEU NOVO FAVICON (Corrigido para leitura com espaços) 🚨 -->
    <link rel="icon" type="image/png" href="/uploads/logo%20favicon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BDTY71XR8Q');
    </script>
</head>
<body class="bg-slate-50 flex flex-col min-h-screen">

    <!-- 🚨 HEADER OTIMIZADO: Fixo no topo com efeito vidro (sticky) 🚨 -->
    <header class="w-full bg-white/95 backdrop-blur-sm z-50 border-b border-slate-200 sticky top-0 shadow-sm transition-all duration-300">
        <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
            <!-- A SUA NOVA LOGOMARCA -->
            <a href="/" class="flex items-center">
                <img src="/uploads/PORTAL STL logo.png" alt="Portal STL" class="h-10 md:h-12 w-auto object-contain">
            </a>
            
            <div class="flex gap-4">
                <a href="#anunciar" class="bg-slate-900 hover:bg-black text-white text-sm font-bold px-6 py-2.5 rounded-full transition shadow-sm">
                    Anuncie
                </a>
            </div>
        </div>
    </header>

    <main class="flex-grow flex flex-col items-center justify-center px-4 py-10 md:py-24 text-center">
        <!-- Título ajustado para mobile (2 linhas) -->
        <h1 class="text-xl min-[400px]:text-2xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 mb-4 tracking-tighter leading-tight">
            O melhor de São Thomé das Letras <br>
            <span class="text-amber-500">a um clique de distância.</span>
        </h1>
        
        <!-- Nova descrição atualizada e unificada -->
        <p class="text-base md:text-xl text-slate-500 max-w-3xl mx-auto mb-8 leading-relaxed">
            Um guia comercial e turístico completo! Encontre empresas, serviços, hospedagens, restaurantes e eventos na <strong class="text-amber-500 font-bold">cidade mais mística do Brasil</strong>.
        </p>

        <form action="/explorar" method="GET" class="w-full max-w-2xl bg-white flex items-center p-2 rounded-full shadow-lg border border-slate-100 transition-all focus-within:ring-4 focus-within:ring-amber-500/20 mb-8">
            <div class="pl-5 text-slate-400">
                <i class="fas fa-search text-xl"></i>
            </div>
            <input type="text" name="busca" placeholder="Pizzarias, Pousadas, Cachoeiras..." class="w-full py-3 md:py-4 px-4 bg-transparent text-slate-700 text-base md:text-lg focus:outline-none placeholder-slate-400" required>
            <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white font-bold text-base md:text-lg py-3 md:py-4 px-6 md:px-8 rounded-full transition shadow-md">
                Buscar
            </button>
        </form>

        <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
            <a href="/explorar" class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-900 hover:text-white px-5 py-2 rounded-full text-sm font-bold transition shadow-sm">
                <i class="fas fa-th-large mr-1"></i> Ver Tudo
            </a>
            <% categorias.forEach(cat => { %>
                <a href="/explorar?categoria=<%= cat.id %>" class="bg-white border border-slate-200 text-slate-600 hover:border-amber-500 hover:text-amber-600 px-5 py-2 rounded-full text-sm font-bold transition shadow-sm">
                    <%= cat.nome %>
                </a>
            <% }) %>
        </div>
    </main>

    <% if (patrocinados && patrocinados.length > 0) { %>
    <section class="py-16 bg-white border-t border-slate-100">
        <div class="max-w-6xl mx-auto px-4">
            <div class="flex justify-between items-end mb-8">
                <div>
                    <!-- 🚨 Título Atualizado 🚨 -->
                    <h2 class="text-3xl font-black text-slate-900">Patrocinados</h2>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <% patrocinados.forEach(local => { %>
                    <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-amber-400 ring-2 ring-amber-400/20 relative flex flex-col hover:-translate-y-1 transition duration-300 group">
                        <div class="absolute top-3 left-3 z-10 bg-amber-500 text-white text-[10px] font-bold px-2.5 py-1 rounded-md uppercase tracking-wide flex items-center gap-1 shadow-sm">
                            <i class="fas fa-crown"></i> Patrocinado
                        </div>
                        
                        <div class="h-48 w-full bg-slate-900 relative overflow-hidden flex-shrink-0 flex items-center justify-center">
                            <% if (local.imagem) { %>
                                <img src="<%= local.imagem %>" alt="<%= local.nome %>" class="w-full h-full object-contain group-hover:scale-105 transition duration-500">
                            <% } else { %>
                                <div class="w-full h-full flex flex-col items-center justify-center bg-slate-100 text-slate-400">
                                    <i class="fas fa-image text-4xl mb-2 opacity-50"></i>
                                </div>
                            <% } %>
                        </div>

                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-extrabold text-xl text-slate-900"><%= local.nome %></h3>
                            <p class="text-slate-500 text-sm mt-1 line-clamp-2"><i class="fas fa-map-marker-alt text-amber-500 mr-1"></i> <%= local.endereco || 'Endereço não informado' %></p>
                            
                            <div class="mt-auto pt-6 flex flex-col gap-3">
                                <!-- URL LIMPA AQUI (Removido o /local) -->
                                <a href="/<%= local.slug %>" class="w-full bg-slate-900 text-white font-bold py-3 rounded-xl text-sm shadow-sm hover:bg-amber-500 hover:text-black transition flex items-center justify-center gap-2">
                                    <i class="fas fa-plus-circle text-lg"></i> + Detalhes
                                </a>
                                
                                <% if(local.whatsapp) { %>
                                    <a href="https://wa.me/55<%= local.whatsapp.replace(/\D/g,'') %>?text=Ol%C3%A1!%20Vi%20o%20seu%20an%C3%BAncio%20no%20Portal%20STL%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es." target="_blank" class="w-full bg-[#25D366] text-white font-bold py-3 rounded-xl text-sm shadow-sm hover:bg-[#128C7E] transition flex items-center justify-center gap-2">
                                        <i class="fab fa-whatsapp text-lg"></i> WhatsApp
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <section id="anunciar" class="py-20 bg-black text-white relative overflow-hidden">
        <div class="absolute top-0 left-0 w-96 h-96 rounded-full bg-white opacity-5 blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full bg-amber-500 opacity-10 blur-3xl translate-x-1/3 translate-y-1/3"></div>
        
        <div class="max-w-[1400px] mx-auto px-4 relative z-10">
            <div class="text-center mb-12 px-2">
                <h2 class="text-3xl sm:text-4xl md:text-5xl font-black mb-4 tracking-tight">Cadastro</h2>
                <p class="text-base sm:text-lg text-zinc-400 max-w-2xl mx-auto leading-relaxed">
                    Cadastre o seu negócio para moradores e turistas que pesquisam no <strong class="text-white">Google</strong> sobre São Thomé das Letras.
                </p>
            </div>

            <% if (locals.sucesso) { %>
                <div class="max-w-3xl mx-auto bg-green-500/20 border border-green-500 text-green-300 p-4 rounded-xl mb-8 font-bold flex items-center justify-center text-center shadow-lg">
                    <p><i class="fas fa-check-circle text-xl mr-2"></i> O seu cadastro foi enviado para aprovação da equipe comercial em até 12h. Acompanhe o Portal STL.</p>
                </div>
            <% } %>

            <div class="flex flex-col gap-12">
                
                <!-- PLANO GRATUITO -->
                <div class="w-full max-w-3xl mx-auto bg-zinc-900 p-8 md:p-10 rounded-3xl shadow-xl border border-zinc-800">
                    <div class="text-center mb-8">
                        <h3 class="text-3xl font-bold mb-3 text-white">Plano Start <span class="text-xl md:text-2xl font-medium text-amber-500">(Gratuito)</span></h3>
                        <p class="text-sm text-zinc-400 leading-relaxed max-w-xl mx-auto mb-5">Coloque a sua empresa ou serviço no mapa digital de São Thomé das Letras. O cadastro do plano básico é gratuito e será enviado para revisão da nossa equipe comercial.</p>
                        
                        <div class="inline-block bg-zinc-800/80 border border-zinc-700/50 rounded-xl px-5 py-3 shadow-inner text-left space-y-2">
                            <p class="text-xs text-zinc-300">
                                <i class="fas fa-info-circle text-amber-500 w-4 text-center"></i> Já possui cadastro e quer alterar/apagar? 
                                <a href="https://wa.me/5535991277497?text=Ol%C3%A1!%20J%C3%A1%20possuo%20um%20cadastro%20no%20Portal%20STL%20e%20gostaria%20de%20solicitar%20uma%20altera%C3%A7%C3%A3o%20ou%20exclus%C3%A3o." target="_blank" class="text-amber-400 hover:text-amber-300 font-bold underline transition ml-1">Clique aqui</a>
                            </p>
                            <p class="text-xs text-zinc-300 border-t border-zinc-700/50 pt-2">
                                <i class="fas fa-tags text-amber-500 w-4 text-center"></i> A sua categoria não está na lista? 
                                <a href="https://wa.me/5535991277497?text=Ol%C3%A1!%20Fui%20fazer%20o%20cadastro%20no%20Portal%20STL,%20mas%20a%20minha%20categoria%20n%C3%A3o%20est%C3%A1%20na%20lista.%20Podem%20adicionar?" target="_blank" class="text-amber-400 hover:text-amber-300 font-bold underline transition ml-1">Fale com o suporte</a>
                            </p>
                        </div>
                    </div>

                    <form action="/contato" method="POST" class="space-y-5">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">Nome Comercial *</label>
                                <input type="text" name="nome" class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-amber-500 focus:outline-none transition" required>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">Categoria *</label>
                                <select name="categoria_id" class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-amber-500 focus:outline-none transition" required>
                                    <% categorias.forEach(cat => { %>
                                        <option value="<%= cat.id %>"><%= cat.nome %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">WhatsApp *</label>
                                <input type="text" name="whatsapp" placeholder="(35) 9..." class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-amber-500 focus:outline-none transition" required>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">Endereço Físico</label>
                                <input type="text" name="endereco" placeholder="Ex: Rua Direita, 10" class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-amber-500 focus:outline-none transition">
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-1 gap-5">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">Link do Google Maps</label>
                                <input type="url" name="link_maps" placeholder="https://maps.app.goo.gl/..." class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-amber-500 focus:outline-none transition">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">Site</label>
                                <input type="text" name="site" class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white text-sm focus:border-amber-500 transition">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-400 mb-1">Instagram</label>
                                <input type="text" name="instagram" class="w-full bg-black border border-zinc-800 rounded-lg py-3 px-4 text-white text-sm focus:border-amber-500 transition">
                            </div>
                        </div>

                        <button type="submit" class="w-full bg-zinc-800 hover:bg-zinc-700 text-white font-bold py-4 rounded-xl transition mt-4 text-lg">
                            Enviar para Aprovação
                        </button>
                    </form>
                </div>

                <!-- PLANOS PAGOS -->
                <div class="w-full max-w-5xl mx-auto bg-gradient-to-br from-amber-400 to-orange-500 p-8 md:p-12 rounded-3xl shadow-2xl relative overflow-hidden">
                    
                    <div class="absolute top-0 right-0 w-80 h-80 bg-white opacity-20 rounded-full blur-3xl transform translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
                    
                    <div class="text-center mb-10 relative z-10">
                        <h3 class="text-4xl font-black text-white drop-shadow-md">Acelere os seus Resultados</h3>
                        <p class="text-amber-100 font-medium mt-2 text-lg">Conquiste a atenção total com os nossos planos exclusivos.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
                        
                        <!-- VITRINE PREMIUM -->
                        <div class="bg-white rounded-2xl p-8 md:p-10 shadow-xl flex flex-col h-full transform hover:-translate-y-2 transition duration-300">
                            <div class="mb-8">
                                <h4 class="text-3xl font-bold text-slate-900 flex items-center gap-2">
                                    <i class="fas fa-star text-amber-500"></i> Vitrine Premium
                                </h4>
                            </div>
                            
                            <ul class="text-base text-slate-600 space-y-5 mb-8 flex-grow font-medium">
                                <li class="flex items-start gap-3"><i class="fas fa-check-circle text-green-500 mt-1 text-xl"></i> <span>Destaque topo da pesquisa</span></li>
                                <li class="flex items-start gap-3"><i class="fas fa-check-circle text-green-500 mt-1 text-xl"></i> <span>Foto de capa exclusiva</span></li>
                                <li class="flex items-start gap-3"><i class="fas fa-check-circle text-green-500 mt-1 text-xl"></i> <span>Descrição completa</span></li>
                                <li class="flex items-start gap-3"><i class="fas fa-check-circle text-green-500 mt-1 text-xl"></i> <span>6 imagens e 1 vídeo na galeria</span></li>
                            </ul>
                            
                            <div class="mb-8 flex items-end gap-1 pt-6 border-t border-slate-100">
                                <span class="text-4xl font-black text-slate-900">R$ 99,00</span>
                                <span class="text-slate-500 font-medium mb-1">/anual</span>
                            </div>
                            
                            <a href="https://wa.me/5535991277497?text=Ol%C3%A1!%20Tenho%20interesse%20no%20Plano%20Vitrine%20Premium%20do%20Portal%20STL." target="_blank" class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-5 rounded-xl shadow-lg transition flex items-center justify-center gap-2 mt-auto text-lg">
                                <i class="fab fa-whatsapp text-2xl"></i> Contratar
                            </a>
                        </div>

                        <!-- PATROCINADOS -->
                        <div class="bg-black rounded-2xl p-8 md:p-10 shadow-2xl flex flex-col h-full transform hover:-translate-y-2 transition duration-300 border border-zinc-800 relative">
                            <div class="absolute -top-4 -right-4 bg-red-600 text-white text-xs font-black px-5 py-2 rounded-full shadow-lg transform rotate-3 animate-pulse">
                                MAIS VENDIDO
                            </div>

                            <div class="mb-8">
                                <h4 class="text-3xl font-black text-white flex items-center gap-2">
                                    <i class="fas fa-crown text-amber-400"></i> Patrocinados
                                </h4>
                            </div>
                            
                            <ul class="text-base text-zinc-300 space-y-5 mb-8 flex-grow font-medium">
                                <li class="flex items-start gap-3"><i class="fas fa-check text-amber-400 mt-1 text-lg"></i> <span class="text-white font-bold">Tudo do plano Vitrine Premium</span></li>
                                <li class="flex items-start gap-3"><i class="fas fa-check text-amber-400 mt-1 text-lg"></i> <span>Destaque no topo da sua categoria</span></li>
                                <li class="flex items-start gap-3"><i class="fas fa-check text-amber-400 mt-1 text-lg"></i> <span>Destaque na página inicial</span></li>
                                <li class="flex items-start gap-3"><i class="fas fa-check text-amber-400 mt-1 text-lg"></i> <span>Patrocinado nas Redes Sociais</span></li>
                            </ul>
                            
                            <a href="https://wa.me/5535991277497?text=Ol%C3%A1!%20Quero%20ser%20um%20Patrocinador%20no%20Portal%20STL%20e%20aparecer%20na%20p%C3%A1gina%20inicial." target="_blank" class="w-full bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-400 hover:to-orange-400 text-black font-black py-5 rounded-xl shadow-[0_0_20px_rgba(245,158,11,0.3)] transition flex items-center justify-center gap-2 mt-auto text-lg">
                                <i class="fab fa-whatsapp text-2xl"></i> Contratar
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </section>

    <footer class="bg-black border-t border-zinc-900 py-6">
        <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
            <!-- Rodapé usando o Logo ou Texto. Vou deixar texto aqui para ficar clean -->
            <div class="text-lg font-black tracking-tight text-zinc-700">
                PORTAL<span class="text-amber-700">STL</span>
            </div>
            <p class="text-zinc-500 text-xs font-medium">
                © 2026 Portal STL. Uma iniciativa Resultados Online.
            </p>
            <a href="/admin" class="flex items-center justify-center bg-zinc-900 text-zinc-600 hover:text-amber-500 hover:bg-zinc-800 w-10 h-10 rounded-full transition shadow-inner" title="Acesso Restrito">
                <i class="fas fa-lock text-sm"></i>
            </a>
        </div>
    </footer>

</body>
</html>
