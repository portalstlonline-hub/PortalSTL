<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Portal São Thomé das Letras - Guia Comercial e Turístico</title>
    <meta name="description" content="Encontre as melhores empresas, pousadas e serviços em São Thomé das Letras - MG. O seu guia completo da cidade mística.">
    
    <link rel="stylesheet" href="/css/style.css">

    <meta name="google-site-verification" content="COLE_AQUI_O_CODIGO_DO_SEARCH_CONSOLE" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDTY71XR8Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-BDTY71XR8Q');
    </script>
</head>
<body>

    <header class="main-header">
        <div class="container">
            <h1 class="logo">Portal STL</h1>
            <nav>
                <ul>
                    <li><a href="/">Início</a></li>
                    <li><a href="#categorias">Categorias</a></li>
                    <li><a href="/admin">Anunciar</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <section class="hero">
        <div class="hero-content">
            <h2>Descubra o melhor de São Thomé das Letras</h2>
            <form action="/busca" method="GET" class="search-box">
                <input type="text" name="q" placeholder="O que você procura? (Pousadas, Restaurantes...)">
                <button type="submit">Buscar</button>
            </form>
        </div>
    </section>

    <section id="categorias" class="container">
        <h3>Explorar por Categoria</h3>
        <div class="grid-categorias">
            <% categorias.forEach(function(cat) { %>
                <a href="/categoria/<%= cat.slug %>" class="card-categoria">
                    <img src="/img/icones/<%= cat.slug %>.png" alt="<%= cat.nome %>">
                    <span><%= cat.nome %></span>
                </a>
            <% }); %>
        </div>
    </section>

    <section class="destaques container">
        <h3>Empresas em Destaque</h3>
        <div class="grid-empresas">
            <% empresas.forEach(function(emp) { %>
                <div class="card-empresa">
                    <h4><%= emp.nome %></h4>
                    <p><%= emp.descricao.substring(0, 100) %>...</p>
                    <a href="/detalhes/<%= emp.id %>" class="btn-ver-mais">Ver Detalhes</a>
                </div>
            <% }); %>
        </div>
    </section>

    <footer class="main-footer">
        <div class="container">
            <p>&copy; 2026 Portal São Thomé das Letras. Uma iniciativa Resultados Online.</p>
            <p>CEO: Daniel Paiva</p>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>