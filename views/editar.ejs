<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar: <%= empresa.nome %> - Portal STL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <header class="bg-slate-900 text-white py-4 px-6 shadow-md sticky top-0 z-50">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <div class="text-xl font-black tracking-tight text-slate-100">
                PORTAL<span class="text-amber-500">STL</span> <span class="text-slate-400 font-normal text-sm ml-2">| Edição</span>
            </div>
            <a href="/admin" class="bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2 border border-slate-700">
                <i class="fas fa-arrow-left"></i> Voltar ao Painel
            </a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-10">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-10">
            <form action="/admin/atualizar/<%= empresa.id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
                
                <!-- BLOCO 1: INFORMAÇÕES PRINCIPAIS (Sempre Visível) -->
                <h3 class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b flex items-center gap-2">
                    <i class="fas fa-info-circle text-amber-500"></i> Informações Principais
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Nome Comercial *</label>
                        <input type="text" name="nome" value="<%= empresa.nome %>" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition" required>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Categoria *</label>
                        <select name="categoria_id" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition" required>
                            <% categorias.forEach(cat => { %>
                                <option value="<%= cat.id %>" <%= cat.id === empresa.categoria_id ? 'selected' : '' %>><%= cat.nome %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Plano de Destaque</label>
                        <select name="plano_id" id="planoSelect" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 transition font-medium">
                            <option value="1" <%= empresa.plano_id === 1 ? 'selected' : '' %>>Start (Grátis)</option>
                            <option value="2" <%= empresa.plano_id === 2 ? 'selected' : '' %>>Premium Vitrine</option>
                            <option value="3" <%= empresa.plano_id === 3 ? 'selected' : '' %>>Patrocinado</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Status</label>
                        <select name="status" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 transition font-bold">
                            <option value="ativo" <%= empresa.status === 'ativo' ? 'selected' : '' %>>🟢 Ativo (Publicado)</option>
                            <option value="inativo" <%= empresa.status === 'inativo' ? 'selected' : '' %>>🔴 Inativo (Rascunho)</option>
                        </select>
                    </div>
                </div>

                <!-- BLOCO 2: CONTATOS E LOCALIZAÇÃO (Sempre Visível) -->
                <h3 class="text-lg font-bold text-slate-900 mt-8 mb-4 pb-2 border-b flex items-center gap-2">
                    <i class="fas fa-address-book text-amber-500"></i> Contactos e Localização
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">WhatsApp</label>
                        <input type="text" name="whatsapp" value="<%= empresa.whatsapp || '' %>" placeholder="Ex: 35999999999" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Site Oficial</label>
                        <input type="url" name="site" value="<%= empresa.site || '' %>" placeholder="https://..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Instagram (@)</label>
                        <input type="text" name="instagram" value="<%= empresa.instagram || '' %>" placeholder="@suaempresa" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Facebook</label>
                        <input type="url" name="facebook" value="<%= empresa.facebook || '' %>" placeholder="Link do perfil" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-slate-700 mb-1">Endereço Físico</label>
                        <input type="text" name="endereco" value="<%= empresa.endereco || '' %>" placeholder="Ex: Rua Direita, 10 - Centro" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-slate-700 mb-1">Link do Google Maps</label>
                        <input type="url" name="link_maps" value="<%= empresa.link_maps || '' %>" placeholder="https://maps.app.goo.gl/..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>
                </div>

                <!-- BLOCO 3: MÍDIA E GALERIA (Dinâmico: Oculto no Plano Start) -->
                <div id="secaoMidia" class="transition-opacity duration-300">
                    <h3 class="text-lg font-bold text-slate-900 mt-8 mb-4 pb-2 border-b flex items-center gap-2">
                        <i class="fas fa-camera text-amber-500"></i> Mídia e Galeria (Planos Pagos)
                    </h3>

                    <div class="mb-5">
                        <label class="block text-sm font-bold text-slate-700 mb-1">Descrição do Negócio</label>
                        <textarea name="descricao" rows="5" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition resize-none"><%= empresa.descricao || '' %></textarea>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-bold text-slate-700 mb-1">Link de Vídeo (YouTube)</label>
                        <input type="url" name="video_url" value="<%= empresa.video_url || '' %>" placeholder="https://www.youtube.com/watch?v=..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-amber-500 outline-none transition">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="bg-slate-50 p-5 rounded-xl border border-dashed border-slate-300">
                            <label class="block text-sm font-bold text-slate-700 mb-3 flex items-center gap-2">
                                <i class="fas fa-image text-slate-400"></i> Foto de Capa Principal
                            </label>
                            <% if(empresa.imagem) { %>
                                <img src="<%= empresa.imagem %>" class="w-full h-32 object-cover rounded-lg mb-3 border border-slate-200">
                            <% } %>
                            <input type="file" name="foto" accept="image/*" class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-slate-200 file:text-slate-700 hover:file:bg-slate-300 transition cursor-pointer">
                        </div>

                        <div class="bg-amber-50 p-5 rounded-xl border border-dashed border-amber-300">
                            <label class="block text-sm font-bold text-amber-800 mb-3 flex items-center gap-2">
                                <i class="fas fa-images text-amber-500"></i> Galeria de Fotos (Até 6)
                            </label>
                            <input type="file" name="galeria" accept="image/*" multiple class="w-full text-sm text-amber-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-amber-500 file:text-white hover:file:bg-amber-600 transition cursor-pointer">
                            <p class="text-[10px] text-amber-600 mt-3 font-semibold uppercase tracking-wider italic">
                                <i class="fas fa-info-circle"></i> Selecione até 6 imagens segurando CTRL/CMD.
                            </p>
                        </div>
                    </div>
                </div> <!-- Fim da Seção Mídia -->

                <!-- BOTÕES DE AÇÃO -->
                <div class="mt-10 pt-6 border-t flex flex-col md:flex-row gap-3">
                    <button type="submit" class="w-full md:w-2/3 bg-slate-900 hover:bg-black text-white font-bold py-4 rounded-xl transition shadow-md flex justify-center items-center gap-2 text-lg">
                        <i class="fas fa-save"></i> Salvar Alterações
                    </button>
                    <a href="/admin/excluir/<%= empresa.id %>" onclick="return confirm('ALERTA! Tem certeza que deseja apagar esta empresa definitivamente?')" class="w-full md:w-1/3 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white font-bold py-4 rounded-xl border border-red-200 transition text-center flex justify-center items-center gap-2">
                        <i class="fas fa-trash-alt"></i> Excluir
                    </a>
                </div>
            </form>
        </div>
    </main>

    <!-- O Mágico do JavaScript (Mostra/Esconde a Mídia) -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const planoSelect = document.getElementById('planoSelect');
            const secaoMidia = document.getElementById('secaoMidia');

            function atualizarVisibilidade() {
                if (planoSelect && secaoMidia) {
                    // Se for Plano 1 (Start Grátis), esconde Mídia/Galeria
                    if (planoSelect.value === '1') {
                        secaoMidia.style.display = 'none';
                    } else {
                        secaoMidia.style.display = 'block';
                    }
                }
            }

            // Executa na carga da página
            atualizarVisibilidade();
            
            // Fica atento às mudanças no menu de planos
            if (planoSelect) {
                planoSelect.addEventListener('change', atualizarVisibilidade);
            }
        });
    </script>
</body>
</html>
